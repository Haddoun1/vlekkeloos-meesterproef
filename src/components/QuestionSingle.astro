---
const { question, options, name } = Astro.props;
---

<div class="question">
  <!-- <p>{question}</p> -->

  <div class="questions-single">
    {
      options.map((opt) => (
        <label>
          <input type="radio" name={name} value={opt} />
          {opt}
        </label>
      ))
    }
  </div>
</div>

<style>
  :global(.panel-right) {
    display: flex;
    flex-direction: column;
    flex: 1;
    width: 100%;
    min-width: 0;
  }

  :global(.text-section) {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--size-2xl) !important;
  }

  :global(.question-wrapper) {
    flex: 1;
    display: flex;
    width: 100%;
  }

  .question {
    display: flex;
    flex-direction: column;
    flex: 1;
    width: 100%;
    height: 100%;
  }

  .questions-single {
    flex: 1;
    width: 100%;

    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: var(--size-base);
  }

  .questions-single label {
    padding: 0.6em;
    font-size: var(--size-sm);
    border: 1px solid #73747a;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    flex-direction: row;
    color: #73747a;
    transition: 0.5s;
    text-align: center;
    height: 100%;
    align-items: center;
    justify-content: center;

    font-family: var(--font-medium);

    &:has(input[type="radio"]:checked) {
      background-color: var(--color-cyan-dark);
      border-color: var(--color-cyan-dark);
      color: var(--color-background);
      font-family: var(--font-bold);
    }
  }

  .questions-single input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
</style>
