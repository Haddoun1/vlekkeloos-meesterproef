<input type="checkbox" id="theme-toggle-checkbox" class="theme-toggle-checkbox" />

<label for="theme-toggle-checkbox" class="theme-toggle-label" aria-label="Schakel thema">
<span class="theme-toggle-icon-light">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"/>
    <line x1="12" y1="2" x2="12" y2="4"/>
    <line x1="12" y1="20" x2="12" y2="22"/>
    <line x1="2" y1="12" x2="4" y2="12"/>
    <line x1="20" y1="12" x2="22" y2="12"/>
    <line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/>
    <line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/>
    <line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/>
    <line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/>
  </svg>
</span>
<span class="theme-toggle-icon-dark">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</span>


</label>

<style>
  .theme-toggle-checkbox {
    display: none;
  }

  .theme-toggle-label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    border: 2px solid var(--color-text);
    border-radius: 50px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: var(--size-base);
    transition: background-color 0.2s ease;
    &:hover {
      background-color: var(--color-cyan);
    }
  }

  .theme-toggle-icon-dark { display: none; }

  :global(html:has(#theme-toggle-checkbox:checked)) .theme-toggle-icon-light { display: none; }
  :global(html:has(#theme-toggle-checkbox:checked)) .theme-toggle-icon-dark { display: block; }
</style>

<script>
//@ts-nocheck
  document.addEventListener("astro:page-load", () => {
    const themeToggleCheckbox = document.getElementById("theme-toggle-checkbox");
    if (!themeToggleCheckbox) return;

    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark") themeToggleCheckbox.checked = true;

    themeToggleCheckbox.addEventListener("change", () => {
      localStorage.setItem("theme", themeToggleCheckbox.checked ? "dark" : "light");
    });
  });
</script>