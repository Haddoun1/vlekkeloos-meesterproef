---
const {
  title,
  description = '',
  image = '',
  progress = 0,
  href = '#',
  color = '#2AB789'
} = Astro.props;
---

<a
  href={href}
  class="course-card"
  style={`--bg-image: url(${image}); --bg-color: ${color};`}
>

  <div class="image-wrapper">
    <img src={image} alt={title}/>
  </div>

  <div class="card-title">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <div class="progress-row">
    <progress
      data-progress-bar
      value={progress}
      max="100"
    >
      {progress}%
    </progress>

    <span
      data-progress-text
      class="progress-label"
    >
      {progress}%
    </span>
  </div>
</a>

