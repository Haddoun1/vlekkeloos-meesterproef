---
const {
  title,
  description = "",
  image = "",
  progress = 0,
  href = "#",
  color = "#2AB789",
} = Astro.props;
---

<a
  href={href}
  class="course-card"
  style={`--bg-image: url(${image}); --bg-color: ${color};`}
>
  <div class="image-wrapper">
    <img src={image} alt={title} />
  </div>

  <div class="card-title">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <div class="progress-row">
    <progress data-progress-bar value={progress} max="100">
      {progress}%
    </progress>

    <span data-progress-text class="progress-label">
      {progress}%
    </span>
  </div>
</a>

<style>
  .course-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;

    text-decoration: none;
    color: var(--color-text);

    background-color: var(--bg-color);
    padding: var(--size-xl);
    border-radius: 12px;
    transition: all 0.3s ease;

    & .image-wrapper {
      width: 60%;
      height: auto;
      margin: 0 auto auto auto;
    }

    & .card-title {
      margin-bottom: 1rem;

      & h2 {
        margin-top: 0.5rem;
        font-size: var(--size-xl);
        font-family: var(--font-extra-bold);
      }

      & p {
        font-size: var(--size-base);
        font-family: var(--font-medium);
      }
    }

    &:hover {
      background-color: color-mix(in srgb, var(--bg-color) 85%, black);
      scale: 1.02;
    }
  }

  .progress-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: var(--size-xxs) var(--size-base);
    border-radius: 999px;

    background-color: color-mix(in srgb, var(--bg-color) 75%, black);
  }

  progress {
    flex: 1;
    height: 8px;
    border: none;
    border-radius: 999px;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.3);
  }

  progress::-webkit-progress-bar {
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 999px;
  }

  progress::-webkit-progress-value {
    background-color: #fff;
    border-radius: 999px;
    transition: all 0.4s ease;
  }

  progress::-moz-progress-bar {
    background-color: #fff;
    border-radius: 999px;
  }

  .progress-label {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    min-width: 3rem;
    text-align: right;
  }

  @media (min-width: 768px) {
    .course-card {
      padding: var(--size-2xl);

      & .card-title {
        & p {
          font-size: 0.9rem;
        }
      }
    }
  }
</style>
