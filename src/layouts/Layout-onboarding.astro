---
// @ts-nocheck
import { ClientRouter } from "astro:transitions";
import BaseHead from '../components/BaseHead.astro';


const bounceTransition = {
  forwards: {
    old: {
      name: "bounceOut",
      duration: "0.3s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "bounceIn",
      duration: "0.4s",
      easing: "cubic-bezier(0.34, 1.3, 0.64, 1)",
      fillMode: "backwards",
      delay: "0.3s",
    },
  },
  backwards: {
    old: {
      name: "bounceOutRight",
      duration: "0.3s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "bounceInLeft",
      duration: "0.4s",
      easing: "cubic-bezier(0.34, 1.3, 0.64, 1)",
      fillMode: "backwards",
      delay: "0.3s",
    },
  },
};

const {
  title,
  nextHref = "/",
  backHref = "/",
  headingText = "Welkom!",
  bodyText = "...",
  step = 1,
  totalSteps = 5,
  stepId,
  category,
  showBack = true,
  showProgress = true,
  showNext = true,
  mockupSrc = "",
  variant = "",
  showDashboardButton = true,
} = Astro.props;

// https://claude.ai/chat/8789b362-5b69-4d5c-9b16-a4b157d09820 button back niet op welkompagina, wel op rest van stappen
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/onboarding.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png?v=2" />
      <BaseHead title={title} />
  <link rel="stylesheet" href="/styles/onboarding.css" />
  <ClientRouter />
</script>
  </head>

  <body>
    <main
      class={`container ${variant}`}
      data-step-id={stepId}
      data-category={category}
    >
      <div class="wrapper-dashboardBtn">
        {
          showDashboardButton && (
            <div class="wrapper-dashboardBtn">
              <a href="/" class="back-button">
                Dashboard
              </a>
            </div>
          )
        }
      </div>
      <div class="logo-mobile">
        <div>
          <img
            class="logo-image logo-image--light"
            src="/images/logohorizontaal.png"
            alt="Stichting Mensenkenners logo"
          />
          <img
            class="logo-image logo-image--dark"
            src="/images/mensenkennerslogowit.png"
            alt="Stichting Mensenkenners logo"
          />
        </div>
      </div>

      <div class="content">
        <!-- Links op desktop: slot voor bv. een afbeelding of illustratie -->
        <div
          class="panel-left"
          transition:name="panel-left"
          transition:animate="none"
        >
          <slot />
        </div>

        <!-- Rechts op desktop: logo, tekst, progress, knoppen -->
        <div class="panel-right">
          {mockupSrc && <img class="mockup" src={mockupSrc} alt="mockup" />}
          <div class="logo-desktop">
                <div>
          <img
            class="logo-image logo-image--light"
            src="/src/assets/logohorizontaal.png"
            alt="Stichting Mensenkenners logo"
          />
          <img
            class="logo-image logo-image--dark"
            src="/src/assets/mensenkennerslogowit.png"
            alt="Stichting Mensenkenners logo"
          />
        </div>
          </div>

          <div
            class="text-section"
            transition:animate="none"
            transition:name="content"
          >
            {
              showProgress && (
                <div class="progress-bar">
                  {Array.from({ length: totalSteps }, (_, i) => (
                    <div
                      class={`progress ${i < step - 1 ? "done-small" : ""} ${i === step - 1 ? "done" : ""}`}
                    />
                  ))}
                </div>
              )
            }

            {
              Astro.slots.has("question") && (
                <div class="question-wrapper">
                  <slot name="question" />
                </div>
              )
            }
            <div class="questionnaire">
              <h1>{headingText}</h1>
              <p>{bodyText}</p>
            </div>
          </div>

          <div class="buttons-onboarding">
            {
              showNext && (
                <a class="button-next" href={nextHref} data-direction="forward">
                  <button>Ga verder</button>
                </a>
              )
            }
            {
              showBack && (
                <a
                  class="button-back"
                  href={backHref}
                  id="back-btn"
                  data-direction="back"
                >
                  <button>Ga terug</button>
                </a>
              )
            }
          </div>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  .logo-image {
    height: 40px;
    width: 160px;
    object-fit: contain;
    object-position: left;
  }

  .logo-image--dark {
    display: none;
  }

  .logo-mobile .logo-image{
    transform: scale(1.8);
  }

  :global(html.dark-mode) .logo-image--light {
    display: none;
  }

  :global(html.dark-mode) .logo-image--dark {
    display: block;
  }
</style>

<!-- https://claude.ai/chat/c67f7248-9580-489f-a97f-bb6489468314 het terugnavigeren met view transitions voor de backbuttons -->
<script>
  // @ts-nocheck
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase";

  let goingBack = false;
  let controller = new AbortController();

  document.addEventListener("astro:before-preparation", () => {
    document.documentElement.classList.toggle("is-going-back", goingBack);
  });

  document.addEventListener("astro:after-swap", () => {
    document.documentElement.classList.toggle("is-going-back", goingBack);
    goingBack = false;
  });

  async function setupTracking() {
    const main = document.querySelector("main");
    const stepId = main?.dataset.stepId;
    const category = main?.dataset.category;
    const startedAt = Date.now();

    const {
      data: { user },
    } = await supabase.auth.getUser();

    async function saveProgress() {
      if (!user?.id) {
        console.warn("Geen ingelogde gebruiker, progress niet opgeslagen.");
        return;
      }

      if (!stepId || !category) {
        console.warn("stepId of category ontbreekt", { stepId, category });
        return;
      }

      const endedAt = Date.now();
      const durationSeconds = Math.round((endedAt - startedAt) / 1000);

      const response = await fetch("/api/track-step", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          userId: user.id,
          email: user.email || localStorage.getItem("email") || null,
          name:
            user.user_metadata?.name || localStorage.getItem("name") || null,
          stepId,
          category,
          currentUrl: window.location.pathname,
          startedAt: new Date(startedAt).toISOString(),
          endedAt: new Date(endedAt).toISOString(),
          durationSeconds,
        }),
      });

      const result = await response.json();
      console.log("Onboarding progress saved:", result);
    }

    return saveProgress;
  }

  async function setupNavigation() {
    controller.abort();
    controller = new AbortController();
    const signal = controller.signal;

    const saveProgress = await setupTracking();

    const backBtn = document.getElementById("back-btn");
    const nextBtn = document.querySelector(".button-next");

    if (backBtn) {
      backBtn.addEventListener(
        "click",
        (e) => {
          e.preventDefault();
          goingBack = true;
          navigate(backBtn.getAttribute("href") ?? "/");
        },
        { signal },
      );
    }

    if (nextBtn) {
      nextBtn.addEventListener(
        "click",
        async (e) => {
          e.preventDefault();
          goingBack = false;

          await saveProgress();

          navigate(nextBtn.getAttribute("href") ?? "/");
        },
        { signal },
      );
    }
  }

  document.addEventListener("astro:page-load", setupNavigation);

  document.addEventListener("astro:after-swap", () => {
    document.documentElement.classList.toggle("is-going-back", goingBack);
    goingBack = false;

    if (localStorage.getItem("theme") === "dark") {
      document.documentElement.classList.add("dark-mode");
    }
  });
</script>

