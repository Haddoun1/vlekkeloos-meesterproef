---
// @ts-nocheck
import data from "../../data/mensenkennersvragen.json";

export async function getStaticPaths() {
  const contents = data.flow.filter(
    (item) => item.type === "Content"
  );

  return contents.map((content, index) => ({
    params: {
      content: String(index + 1),
    },
    props: {
      content,
      index,
      total: contents.length,
    },
  }));
}

const { content, index, total } = Astro.props;

const currentPage = index + 1;

const previousPage =
  currentPage > 1
    ? `/content/${currentPage - 1}`
    : null;

const nextPage =
  currentPage < total
    ? `/content/${currentPage + 1}`
    : null;
---

<h1>Content {currentPage} van {total}</h1>

<section>
  {content.title && <h2>{content.title}</h2>}

  {content.content && <p>{content.content}</p>}

  {content.description && <p>{content.description}</p>}

  {content.text && <p>{content.text}</p>}
</section>

<nav>
  {previousPage && <a href={previousPage}>Vorige</a>}
  {nextPage && <a href={nextPage}>Volgende</a>}
</nav>