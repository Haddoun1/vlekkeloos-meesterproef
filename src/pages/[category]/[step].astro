  transform: translateY(-1px);
  box-shadow: 0 4px 14px color-mix(in srgb, var(--color-accent) 50%, transparent);
}

.back-button:hover::before {
  transform: translateX(-2px);
}

.back-button:active {
  transform: scale(0.97);
}

.card {
  background: rgba(255,255,255,0.72);
