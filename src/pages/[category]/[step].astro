---
// @ts-nocheck
export const prerender = true;
import data from "../../data/mensenkennersvragen.json";
import { slugify } from "../../utils/slugify";


export async function getStaticPaths() {

  const getCategory = (item) => item.Category ?? item.category;
  const getCategorySlug = (item) => slugify(getCategory(item));

  const items = data.blocks.filter(
    (item) =>
      getCategory(item) &&
      ["content", "video", "question"].includes(item.type),
  );

  return items.map((item) => {
    const categorySlug = getCategorySlug(item);
    const categoryItems = items.filter(
      (x) => getCategorySlug(x) === categorySlug,
    );
    const stepIndex = categoryItems.findIndex((x) => x.id === item.id);

    return {
      params: {
        category: categorySlug,
        step: String(stepIndex + 1),
      },
      props: {
        item,
        currentStep: stepIndex + 1,
        totalSteps: categoryItems.length,
        category: getCategory(item),
        categoryItems,
      },
    };
  });
}

const { item, currentStep, totalSteps, category, categoryItems } = Astro.props;
const categorySlug = slugify(category);

const previousPage = currentStep > 1 ? `/${categorySlug}/${currentStep - 1}` : null;
const nextPage = currentStep < totalSteps ? `/${categorySlug}/${currentStep + 1}` : null;

let embedUrl = item.url;
if (item.url?.includes("vimeo.com")) {
  const id = item.url.split("/").filter(Boolean).pop()?.split("?")[0];
  embedUrl = `https://player.vimeo.com/video/${id}`;
}
if (item.url?.includes("youtube.com/watch?v=")) {
  const id = item.url.split("v=")[1]?.split("&")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}
if (item.url?.includes("youtu.be/")) {
  const id = item.url.split("youtu.be/")[1]?.split("?")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

const options = item.options || [];
const scale = item.scale || {};
const minRating = scale.min || 1;
const maxRating = scale.max || 10;
const ratings = Array.from(
  { length: maxRating - minRating + 1 },
  (_, i) => minRating + i,
);

const hasCorrectOptions =
  item.type === "question" &&
  ["single_choice", "multiple_choice"].includes(item.input_type) &&
  options.some((option) => typeof option === "object" && option.is_correct === true);

const isOpenReflectionQuestion =
  item.type === "question" &&
  ["long_text", "sentence_completion"].includes(item.input_type);

const isCheckableQuestion =
  item.type === "question" &&
  (hasCorrectOptions || item.input_type === "matching" || isOpenReflectionQuestion);

const maxSelections = item.max_selections || 2;
const exampleAnswer =
  item.example_answer ||
  item.model_answer ||
  item.sample_answer ||
  item.explanation ||
  "Er is nog geen voorbeeldantwoord ingesteld voor deze vraag. Voeg bijvoorbeeld `example_answer` toe aan deze vraag in de JSON.";

let nextSectionUrl = null;

if (item.id?.endsWith("_submit")) {
  if (item.id === "intro_submit") nextSectionUrl = "/module-1/1";
  if (item.id === "m1_submit") nextSectionUrl = "/module-2/1";
  if (item.id === "m2_submit") nextSectionUrl = "/module-3/1";
  if (item.id === "m3_submit") nextSectionUrl = "/module-4/1";
}

const progressPct = Math.round((currentStep / totalSteps) * 100);

const categoryColorMap: Record<string, string> = {
  "intro": "#B1F2D9",
  "module-1": "#FF94E1",
  "module-2": "#E9F279",
  "module-3": "#FF6631",
  "module-4": "#2241dd",
};

const accentColor = categoryColorMap[categorySlug] ?? "#B1F2D9";
---

<link rel="stylesheet" href="/styles/global.css" />

<!-- Hidden SVG filters for colour-blindness simulation -->
<svg style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true">
  <defs>
    <filter id="cb-protanopia">
      <feColorMatrix type="matrix" values="0.567 0.433 0 0 0  0.558 0.442 0 0 0  0 0.242 0.758 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-deuteranopia">
      <feColorMatrix type="matrix" values="0.625 0.375 0 0 0  0.7 0.3 0 0 0  0 0.3 0.7 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-tritanopia">
      <feColorMatrix type="matrix" values="0.95 0.05 0 0 0  0 0.433 0.567 0 0  0 0.475 0.525 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-achromatopsia">
      <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0  0.299 0.587 0.114 0 0  0.299 0.587 0.114 0 0  0 0 0 1 0"/>
    </filter>
  </defs>
</svg>

<!-- Vertraagde cursor stip (motorieke beperking simulatie) -->
<div class="cursor-dot" id="cursorDot" aria-hidden="true"></div>

<!-- Nav overlay (backdrop) -->
<div class="nav-overlay" id="navOverlay"></div>

<!-- Slide-in nav panel -->
<nav class="nav-panel" id="navPanel" aria-label="Vragennavigatie">
  <div class="nav-panel-header">
    <span class="nav-panel-title">{category}</span>
    <button class="nav-close-btn" id="navCloseBtn" aria-label="Sluit menu"
      >&#10005</button
    >
  </div>
  <ul class="nav-list">
    {
      categoryItems.map((navItem, idx) => (
        <li>
          <a
            href={`/${categorySlug}/${idx + 1}`}
            class={idx + 1 === currentStep ? "active" : ""}
          >
            <span class="nav-step-num">{idx + 1}</span>
            <span class="nav-step-title">
              {navItem.title || navItem.question || `Stap ${idx + 1}`}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<!-- Setting overlay (backdrop) -->
<div class="setting-overlay" id="settingOverlay"></div>

<!-- Slide-in setting panel (from right) -->
<nav class="setting-panel" id="settingPanel" aria-label="Instellingen">
  <div class="setting-panel-header">
    <span class="setting-panel-title">Instellingen</span>
    <button class="setting-close-btn" id="settingCloseBtn" aria-label="Sluit instellingen"
      >&#10005</button
    >
  </div>
  <div class="setting-content">
    <!-- Add settings content here -->
  </div>
</nav>

<div class="page-shell" style={`--color-accent: ${accentColor}`}>
  <aside class="sidebar-left" aria-label="Navigatiemenu"></aside>

  <main
    class="content-col"
    data-step-id={String(currentStep)}
    data-category={categorySlug}
    data-requires-check={isCheckableQuestion ? "true" : "false"}
    data-input-type={item.input_type || ""}
  >
    <header class="page-header">
      <a href="/index.html" class="back-button"> Dashboard </a>
      <p class="category-pill">{category}</p>
      <button
        class="hamburger-btn"
        id="hamburgerBtn"
        aria-label="Open vragennavigatie"
      >
        {currentStep}<span class="step-total">/{totalSteps}</span>
      </button>

      <button
        class="setting-btn"
        id="settingBtn"
        aria-label="Open instellingen"
      >
          &#9881;
      </button>
    </header>

    <section class="card">
      {item.title && <h1 class="card-title">{item.title}</h1>}
      {item.subtitle && <p class="card-subtitle">{item.subtitle}</p>}
      {item.text && <p class="card-body">{item.text}</p>}

      {item.source && (
        <p class="card-source">
          <span class="source-label">Bron</span>
          {item.source}
        </p>
      )}

      {item.type === "video" && embedUrl && embedUrl.trim() !== "" && (
        <div class="video-wrapper">
          <iframe
            src={embedUrl}
            title={item.title}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>
      )}

      {item.type === "question" && (
        <div class="question-block">
          {item.question && <h2 class="question-text">{item.question}</h2>}
          {item.description && <p class="card-body">{item.description}</p>}
          {item.label && <label class="field-label">{item.label}</label>}

          {item.input_type === "text" && (
            <input class="text-input" type="text" placeholder={item.placeholder || "Typ hier je antwoord"} />
          )}

          {item.input_type === "email" && (
            <input class="text-input" type="email" placeholder="Typ hier je e-mailadres" />
          )}

          {item.input_type === "long_text" && (
            <textarea class="text-area" rows="5" placeholder={item.placeholder || "Typ hier je antwoord"} />
          )}

          {item.input_type === "single_choice" && (
            <ul class="options-list" role="radiogroup">
              {options.map((option, index) => {
                const text = typeof option === "string" ? option : option.text;
                return (
                  <li>
                    <label class="option-label">
                      <input
                        type="radio"
                        name={item.id}
                        value={text}
                        class="option-input"
                        data-correct={typeof option === "object" && option.is_correct === true ? "true" : "false"}
                      />
                      <span class="option-key">{String.fromCharCode(65 + index)}</span>
                      <span class="option-text">{text}</span>
                    </label>
                  </li>
                );
              })}
            </ul>
          )}

          {item.input_type === "multiple_choice" && (
            <div data-multiple-choice data-max-selections={maxSelections}>
              <p class="mc-hint">Selecteer maximaal {maxSelections} opties</p>
              <ul class="options-list" role="group">
                {options.map((option, index) => {
                  const text = typeof option === "string" ? option : option.text;
                  return (
                    <li>
                      <label class="option-label">
                        <input
                          type="checkbox"
                          name={item.id}
                          value={text}
                          class="option-input"
                          data-correct={typeof option === "object" && option.is_correct === true ? "true" : "false"}
                        />
                        <span class="option-key">
                          {String.fromCharCode(65 + index)}
                        </span>
                        <span class="option-text">{text}</span>
                      </label>
                    </li>
                  );
                })}
              </ul>
              <div
                class="mc-error"
                role="alert"
                aria-live="polite"
                id="mc-error"
                hidden
              >
                Je kunt maximaal {maxSelections} opties selecteren.
              </div>
            </div>
          )}

          {item.input_type === "rating" && (
            <div class="rating-block">
              {scale.min_label && (
                <span class="rating-label">{scale.min_label}</span>
              )}
              <div class="rating-row">
                {ratings.map((ratingValue) => (
                  <label class="rating-option">
                    <input
                      type="radio"
                      id={`rating-${item.id}-${ratingValue}`}
                      name={`rating-${item.id}`}
                      value={ratingValue}
                      class="option-input"
                    />
                    <span class="rating-pip">{ratingValue}</span>
                  </label>
                ))}
              </div>
              {scale.max_label && (
                <span class="rating-label">{scale.max_label}</span>
              )}
            </div>
          )}

          {item.input_type === "sentence_completion" && (
            <div class="sentence-completion-block">
              <textarea
                class="text-area"
                rows="4"
                name={item.id}
                placeholder={item.placeholder || "Vul je antwoord aan"}
                required={item.required}
              />
            </div>
          )}

          {item.input_type === "matching" && (
            <div class="matching-block" data-matching data-question-id={item.id}>
              <div class="matching-grid">
                {(item.pairs || []).map((pair, index) => (
                  <div class="matching-row">
                    <div class="matching-prompt">
                      <span class="option-key">{String.fromCharCode(65 + index)}</span>
                      <span>{pair.prompt}</span>
                    </div>
                    <select
                      class="matching-select"
                      name={`${item.id}-${index}`}
                      required={item.required}
                      data-correct-answer={pair.answer}
                    >
                      <option value="">Kies een antwoord</option>
                      {(item.pairs || []).map((answerPair) => (
                        <option value={answerPair.answer}>{answerPair.answer}</option>
                      ))}
                    </select>
                  </div>
                ))}
              </div>
            </div>
          )}

          {isCheckableQuestion && (
            <div class="question-check-row">
              <button type="button" class="btn btn--primary" id="check-answer-btn">
                Check antwoord
              </button>
              <div
                class="answer-feedback"
                id="answer-feedback"
                role="status"
                aria-live="polite"
                hidden
                data-explanation={item.explanation || ""}
                data-example-answer={exampleAnswer}
              />
            </div>
          )}
        </div>
      )}

      {
        item.id?.endsWith("_submit") && (
          <div class="action-row">
            <a href="/index.html" class="btn btn--ghost">
              Dashboard
            </a>
            {nextSectionUrl && (
              <a href={nextSectionUrl} class="btn btn--primary">
                Volgend deel
              </a>
            )}
          </div>
        )
      }
    </section>

    <nav class="bottom-nav" aria-label="Navigatie">
      {
        previousPage ? (
          <a class="nav-btn nav-btn--prev" href={previousPage}>
            {" "}
            Vorige
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled" aria-disabled="true">
            {" "}
            Vorige
          </span>
        )
      }

      {
        nextPage ? (
          <a class="nav-btn nav-btn--next" href={nextPage} id="nav-next">
            Volgende{" "}
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled" aria-disabled="true">
            Volgende{" "}
          </span>
        )
      }
    </nav>
  </main>

  <aside class="sidebar-right" aria-hidden="true"></aside>
</div>

<script>
  // @ts-nocheck
  import { supabase } from "../../lib/supabase";

  const main = document.querySelector("main.content-col");
  const navNext = document.getElementById("nav-next");
  const checkAnswerBtn = document.getElementById("check-answer-btn");
  const answerFeedback = document.getElementById("answer-feedback");
  const requiresCheck = main?.dataset.requiresCheck === "true";

  const stepId = main?.dataset.stepId;
  const category = main?.dataset.category;
  const startedAt = new Date();

  let alreadySaved = false;

  async function saveProgress() {
    if (alreadySaved) return;
    if (!stepId || !category) return;

    alreadySaved = true;

    const endedAt = new Date();
    const durationSeconds = Math.round((endedAt - startedAt) / 1000);

    const {
      data: { user },
    } = await supabase.auth.getUser();

    const response = await fetch("/api/track-step", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        userId: user?.id || "anonymous",
        email: user?.email || null,
        name: user?.user_metadata?.name || null,
        stepId,
        category,
        startedAt: startedAt.toISOString(),
        endedAt: endedAt.toISOString(),
        durationSeconds,
      }),
    });

    const result = await response.json();
  }

  function setNextEnabled(enabled) {
    if (!navNext || !requiresCheck) return;

    navNext.dataset.checked = enabled ? "true" : "false";
    navNext.setAttribute("aria-disabled", enabled ? "false" : "true");
    navNext.classList.toggle("nav-btn--disabled", !enabled);
  }

  setNextEnabled(false);

  if (navNext) {
    navNext.addEventListener("click", async (e) => {
      e.preventDefault();

      if (requiresCheck && navNext.dataset.checked !== "true") {
        answerFeedback.hidden = false;
        answerFeedback.className = "answer-feedback answer-feedback--warning";
        answerFeedback.textContent = "Check eerst je antwoord voordat je verdergaat.";
        return;
      }

      await saveProgress();
      window.location.href = navNext.href;
    });
  }

  function escapeHtml(value) {
    return String(value || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function getOptionLabel(input) {
    const label = input.closest(".option-label");
    const key = label?.querySelector(".option-key")?.textContent?.trim();
    const text = label?.querySelector(".option-text")?.textContent?.trim() || input.value;
    return key ? `${key}. ${text}` : text;
  }

  function getCorrectOptionLabels() {
    const correctInputs = document.querySelectorAll(
      ".question-block input[data-correct='true']",
    );

    return [...correctInputs].map(getOptionLabel);
  }

  function markChoiceFeedback() {
    const choiceInputs = document.querySelectorAll(
      ".question-block input[data-correct]",
    );

    choiceInputs.forEach((input) => {
      const label = input.closest(".option-label");
      if (!label) return;

      label.classList.remove("option-label--correct", "option-label--incorrect");

      if (input.dataset.correct === "true") {
        label.classList.add("option-label--correct");
      }

      if (input.checked && input.dataset.correct !== "true") {
        label.classList.add("option-label--incorrect");
      }
    });
  }

  function getMatchingCorrections() {
    const matchingSelects = document.querySelectorAll(".matching-select[data-correct-answer]");

    return [...matchingSelects]
      .filter((select) => select.value !== select.dataset.correctAnswer)
      .map((select) => {
        const prompt = select
          .closest(".matching-row")
          ?.querySelector(".matching-prompt span:last-child")
          ?.textContent
          ?.trim();

        return {
          prompt,
          correctAnswer: select.dataset.correctAnswer,
        };
      });
  }

  function getOpenQuestionResult() {
    const openInput = document.querySelector(
      ".question-block textarea, .question-block input[type='text']",
    );

    if (!openInput) return null;

    if (!openInput.value.trim()) {
      return {
        valid: false,
        message: "Vul eerst je antwoord in.",
      };
    }

    return {
      valid: true,
      correct: true,
      isOpenQuestion: true,
    };
  }

  function getQuestionResult() {
    const inputType = main?.dataset.inputType;

    if (["long_text", "sentence_completion"].includes(inputType)) {
      return getOpenQuestionResult();
    }

    const selectedRadio = document.querySelector(".question-block input[type='radio']:checked");
    const radioOptions = document.querySelectorAll(".question-block input[type='radio'][data-correct]");

    if (radioOptions.length > 0) {
      if (!selectedRadio) {
        return {
          valid: false,
          message: "Kies eerst een antwoord.",
        };
      }

      return {
        valid: true,
        correct: selectedRadio.dataset.correct === "true",
        correctOptions: getCorrectOptionLabels(),
      };
    }

    const checkboxOptions = document.querySelectorAll(".question-block input[type='checkbox'][data-correct]");
    const checkedBoxes = [...checkboxOptions].filter((checkbox) => checkbox.checked);
    const correctBoxes = [...checkboxOptions].filter((checkbox) => checkbox.dataset.correct === "true");

    if (checkboxOptions.length > 0) {
      if (checkedBoxes.length === 0) {
        return {
          valid: false,
          message: "Kies eerst minimaal één antwoord.",
        };
      }

      const allSelectedAreCorrect = checkedBoxes.every((checkbox) => checkbox.dataset.correct === "true");
      const allCorrectSelected = correctBoxes.every((checkbox) => checkbox.checked);

      return {
        valid: true,
        correct: allSelectedAreCorrect && allCorrectSelected,
        correctOptions: getCorrectOptionLabels(),
      };
    }

    const matchingSelects = document.querySelectorAll(".matching-select[data-correct-answer]");

    if (matchingSelects.length > 0) {
      const unanswered = [...matchingSelects].some((select) => !select.value);

      if (unanswered) {
        return {
          valid: false,
          message: "Koppel eerst alle antwoorden.",
        };
      }

      const allCorrect = [...matchingSelects].every(
        (select) => select.value === select.dataset.correctAnswer,
      );

      return {
        valid: true,
        correct: allCorrect,
        matchingCorrections: getMatchingCorrections(),
      };
    }

    return {
      valid: true,
      correct: true,
    };
  }

  function lockQuestionInputs() {
    const inputs = document.querySelectorAll(
      ".question-block input, .question-block textarea, .question-block select",
    );

    inputs.forEach((input) => {
      input.disabled = true;
    });
  }

  checkAnswerBtn?.addEventListener("click", () => {
    const result = getQuestionResult();

    answerFeedback.hidden = false;

    if (!result.valid) {
      answerFeedback.className = "answer-feedback answer-feedback--warning";
      answerFeedback.textContent = result.message;
      return;
    }

    const explanation = answerFeedback.dataset.explanation;
    const exampleAnswer = answerFeedback.dataset.exampleAnswer;

    if (result.isOpenQuestion) {
      answerFeedback.className = "answer-feedback answer-feedback--example";
      answerFeedback.innerHTML = `
        <p>${escapeHtml(exampleAnswer)}</p>
      `;
    } else if (result.correct) {
      markChoiceFeedback();
      answerFeedback.className = "answer-feedback answer-feedback--correct";
      answerFeedback.textContent = explanation
        ? `Goed! ${explanation}`
        : "Goed! Dit antwoord klopt.";
    } else {
      markChoiceFeedback();
      answerFeedback.className = "answer-feedback answer-feedback--incorrect";

      const correctOptions = result.correctOptions || [];
      const matchingCorrections = result.matchingCorrections || [];

      let feedbackHtml = explanation
        ? `<strong>Niet helemaal.</strong><p>${escapeHtml(explanation)}</p>`
        : "<strong>Niet helemaal.</strong>";

      if (correctOptions.length > 0) {
        feedbackHtml += `
          <p><strong>Het juiste antwoord${correctOptions.length > 1 ? "en waren" : " was"}:</strong></p>
          <ul>${correctOptions.map((option) => `<li>${escapeHtml(option)}</li>`).join("")}</ul>
        `;
      }

      if (matchingCorrections.length > 0) {
        feedbackHtml += `
          <p><strong>Juiste koppelingen:</strong></p>
          <ul>
            ${matchingCorrections
              .map(
                (item) => `<li>${escapeHtml(item.prompt)}: ${escapeHtml(item.correctAnswer)}</li>`,
              )
              .join("")}
          </ul>
        `;
      }

      answerFeedback.innerHTML = feedbackHtml;
    }

    lockQuestionInputs();
    checkAnswerBtn.disabled = true;
    checkAnswerBtn.textContent = "Gecheckt";
    setNextEnabled(true);
  });

  const mcBlock = document.querySelector("[data-multiple-choice]");

  if (mcBlock) {
    const checkboxes = mcBlock.querySelectorAll("input[type='checkbox']");
    const errorEl = document.getElementById("mc-error");

    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", (e) => {
        const checked = [...checkboxes].filter((cb) => cb.checked);
        const maxSelections = Number(mcBlock.dataset.maxSelections || 2);

        const maxSelections = Number(mcBlock.dataset.maxSelections || 2);

        if (checked.length > maxSelections) {
          e.target.checked = false;

          if (errorEl) {
            errorEl.hidden = false;
            clearTimeout(errorEl._timer);
            errorEl._timer = setTimeout(() => {
              errorEl.hidden = true;
            }, 3000);
          }
        } else {
          if (errorEl) errorEl.hidden = true;
        }
      });
    });
  }

  // ── Hamburger nav ──────────────────────────────────────────────
  const hamburgerBtn = document.getElementById("hamburgerBtn");
  const navPanel = document.getElementById("navPanel");
  const navOverlay = document.getElementById("navOverlay");
  const navCloseBtn = document.getElementById("navCloseBtn");

  function openNav() {
    navPanel?.classList.add("open");
    navOverlay?.classList.add("open");
    hamburgerBtn?.classList.add("open");
    hamburgerBtn?.setAttribute("aria-expanded", "true");
  }

  function closeNav() {
    navPanel?.classList.remove("open");
    navOverlay?.classList.remove("open");
    hamburgerBtn?.classList.remove("open");
    hamburgerBtn?.setAttribute("aria-expanded", "false");
  }

  hamburgerBtn?.addEventListener("click", () =>
    navPanel?.classList.contains("open") ? closeNav() : openNav(),
  );
  navCloseBtn?.addEventListener("click", closeNav);
  navOverlay?.addEventListener("click", closeNav);

  // ── Setting nav ──────────────────────────────────────────────
  const settingBtn = document.getElementById("settingBtn");
  const settingPanel = document.getElementById("settingPanel");
  const settingOverlay = document.getElementById("settingOverlay");
  const settingCloseBtn = document.getElementById("settingCloseBtn");

  function openSetting() {
    settingPanel?.classList.add("open");
    settingOverlay?.classList.add("open");
    settingBtn?.classList.add("open");
    settingBtn?.setAttribute("aria-expanded", "true");
  }

  function closeSetting() {
    settingPanel?.classList.remove("open");
    settingOverlay?.classList.remove("open");
    settingBtn?.classList.remove("open");
    settingBtn?.setAttribute("aria-expanded", "false");
  }

  settingBtn?.addEventListener("click", () =>
    settingPanel?.classList.contains("open") ? closeSetting() : openSetting(),
  );
  settingCloseBtn?.addEventListener("click", closeSetting);
  settingOverlay?.addEventListener("click", closeSetting);
</script>

