---
// @ts-nocheck
export const prerender = true;
import data from "../../data/mensenkennersvragen.json";
import { slugify } from "../../utils/slugify";


export async function getStaticPaths() {

  const getCategory = (item) => item.Category ?? item.category;
  const getCategorySlug = (item) => slugify(getCategory(item));

  const items = data.blocks.filter(
    (item) =>
      getCategory(item) &&
      ["content", "video", "question"].includes(item.type),
  );

  return items.map((item) => {
    const categorySlug = getCategorySlug(item);
    const categoryItems = items.filter(
      (x) => getCategorySlug(x) === categorySlug,
    );
    const stepIndex = categoryItems.findIndex((x) => x.id === item.id);

    return {
      params: {
        category: categorySlug,
        step: String(stepIndex + 1),
      },
      props: {
        item,
        currentStep: stepIndex + 1,
        totalSteps: categoryItems.length,
        category: getCategory(item),
        categoryItems,
      },
    };
  });
}

const { item, currentStep, totalSteps, category, categoryItems } = Astro.props;
const categorySlug = slugify(category);

const previousPage = currentStep > 1 ? `/${categorySlug}/${currentStep - 1}` : null;
const nextPage = currentStep < totalSteps ? `/${categorySlug}/${currentStep + 1}` : null;

let embedUrl = item.url;
if (item.url?.includes("vimeo.com")) {
  const id = item.url.split("/").filter(Boolean).pop()?.split("?")[0];
  embedUrl = `https://player.vimeo.com/video/${id}`;
}
if (item.url?.includes("youtube.com/watch?v=")) {
  const id = item.url.split("v=")[1]?.split("&")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}
if (item.url?.includes("youtu.be/")) {
  const id = item.url.split("youtu.be/")[1]?.split("?")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

const options = item.options || [];
const scale = item.scale || {};
const minRating = scale.min || 1;
const maxRating = scale.max || 10;
const ratings = Array.from(
  { length: maxRating - minRating + 1 },
  (_, i) => minRating + i,
);

let nextSectionUrl = null;
if (item.id?.endsWith("_submit")) {
  if (item.id === "intro_submit") nextSectionUrl = "/Module-1/1";
  if (item.id === "d1_submit") nextSectionUrl = "/Module-2/1";
  if (item.id === "d2_submit") nextSectionUrl = "/Module-3/1";
}

const progressPct = Math.round((currentStep / totalSteps) * 100);

const categoryColorMap: Record<string, string> = {
  "intro": "#B1F2D9",
  "module-1": "#FF94E1",
  "module-2": "#E9F279",
  "module-3": "#FF6631",
  "module-4": "#2241dd",
};

const accentColor = categoryColorMap[categorySlug] ?? "#B1F2D9";
---

<link rel="stylesheet" href="/styles/global.css" />

<!-- Hidden SVG filters for colour-blindness simulation -->
<svg style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true">
  <defs>
    <filter id="cb-protanopia">
      <feColorMatrix type="matrix" values="0.567 0.433 0 0 0  0.558 0.442 0 0 0  0 0.242 0.758 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-deuteranopia">
      <feColorMatrix type="matrix" values="0.625 0.375 0 0 0  0.7 0.3 0 0 0  0 0.3 0.7 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-tritanopia">
      <feColorMatrix type="matrix" values="0.95 0.05 0 0 0  0 0.433 0.567 0 0  0 0.475 0.525 0 0  0 0 0 1 0"/>
    </filter>
    <filter id="cb-achromatopsia">
      <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0  0.299 0.587 0.114 0 0  0.299 0.587 0.114 0 0  0 0 0 1 0"/>
    </filter>
  </defs>
</svg>

<!-- ── Accessibility simulator ─────────────────────────────────── -->
<div class="a11y-fab-wrap" id="a11yFabWrap">

  <!-- Floating toggle button -->
  <button class="a11y-fab" id="a11yFab" aria-expanded="false" aria-controls="a11yPanel" aria-label="Toegankelijkheid simuleren">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="5" r="1.5"/><path d="M7 9h10M10 9v10M14 9v10"/>
    </svg>
    <span class="a11y-fab-label">Toegankelijkheid</span>
    <span class="a11y-active-dot" id="a11yActiveDot" hidden></span>
  </button>

  <!-- Slide-down panel -->
  <div class="a11y-panel" id="a11yPanel" hidden>

    <div class="a11y-section">
      <div class="a11y-section-title">Kleuren &amp; contrast</div>

      <div class="a11y-row">
        <div class="a11y-label">Kleurenschema<small>Licht / donker</small></div>
        <div class="a11y-radios" id="schemeGroup">
          <button class="a11y-chip active" data-val="light">Licht</button>
          <button class="a11y-chip" data-val="dark">Donker</button>
          <button class="a11y-chip" data-val="system">Systeem</button>
        </div>
      </div>

      <div class="a11y-row">
        <div class="a11y-label">Kleurenblindheid<small>Type simulatie</small></div>
        <div class="a11y-radios" id="colorblindGroup">
          <button class="a11y-chip active" data-val="none">Geen</button>
          <button class="a11y-chip" data-val="cb-protanopia">Protanopie</button>
          <button class="a11y-chip" data-val="cb-deuteranopia">Deuteranopie</button>
          <button class="a11y-chip" data-val="cb-tritanopia">Tritanopie</button>
          <button class="a11y-chip" data-val="cb-achromatopsia">Achromatopsie</button>
        </div>
      </div>

      <div class="a11y-row">
        <div class="a11y-label">Contrast<small>Lager = slechter zicht</small></div>
        <div class="a11y-slider-wrap">
          <input type="range" id="contrastRange" min="0" max="200" value="100" step="1" />
          <span class="a11y-val" id="contrastVal">100%</span>
        </div>
      </div>

      <div class="a11y-row">
        <div class="a11y-label">Helderheid</div>
        <div class="a11y-slider-wrap">
          <input type="range" id="brightnessRange" min="10" max="200" value="100" step="1" />
          <span class="a11y-val" id="brightnessVal">100%</span>
        </div>
      </div>
    </div>

    <div class="a11y-section">
      <div class="a11y-section-title">Zicht &amp; focus</div>

      <div class="a11y-row">
        <div class="a11y-label">Wazig zicht<small>Simuleer slechtziendheid</small></div>
        <div class="a11y-slider-wrap">
          <input type="range" id="blurRange" min="0" max="10" value="0" step="0.1" />
          <span class="a11y-val" id="blurVal">0</span>
        </div>
      </div>

    </div>

    <div class="a11y-section">
      <div class="a11y-section-title">Lezen &amp; tekst</div>

      <div class="a11y-row">
        <div class="a11y-label">Dyslexie<small>Letterverwisseling</small></div>
        <div class="a11y-radios" id="dyslexiaGroup">
          <button class="a11y-chip active" data-val="0">Uit</button>
          <button class="a11y-chip" data-val="1">Licht</button>
          <button class="a11y-chip" data-val="2">Matig</button>
          <button class="a11y-chip" data-val="3">Zwaar</button>
          <button class="a11y-chip" data-val="4">Extreem</button>
        </div>
      </div>

    </div>

    <div class="a11y-section">
      <div class="a11y-section-title">Beweging &amp; interactie</div>

      <div class="a11y-row">
        <div class="a11y-label">Trilling<small>Simuleer tremor</small></div>
        <div class="a11y-slider-wrap">
          <input type="range" id="tremorRange" min="0" max="5" value="0" step="0.5" />
          <span class="a11y-val" id="tremorVal">0</span>
        </div>
      </div>

      <div class="a11y-row">
        <div class="a11y-label">Cursor vertraging<small>Motorieke beperking</small></div>
        <div class="a11y-radios" id="cursorDelayGroup">
          <button class="a11y-chip active" data-val="0">Uit</button>
          <button class="a11y-chip" data-val="0.8">Aan</button>
        </div>
      </div>
    </div>

    <div class="a11y-footer">
      <button class="a11y-reset" id="a11yReset">↺ Reset alle instellingen</button>
    </div>

  </div>
</div>
<!-- Vertraagde cursor stip (motorieke beperking simulatie) -->
<div class="a11y-cursor-dot" id="a11yCursorDot" aria-hidden="true"></div>
<!-- ── /Accessibility simulator ────────────────────────────────── -->

<!-- Nav overlay (backdrop) -->
<div class="nav-overlay" id="navOverlay"></div>

<!-- Slide-in nav panel -->
<nav class="nav-panel" id="navPanel" aria-label="Vragennavigatie">
  <div class="nav-panel-header">
    <span class="nav-panel-title">{category}</span>
    <button class="nav-close-btn" id="navCloseBtn" aria-label="Sluit menu"
      >&#10005</button
    >
  </div>
  <ul class="nav-list">
    {
      categoryItems.map((navItem, idx) => (
        <li>
          <a
            href={`/${categorySlug}/${idx + 1}`}
            class={idx + 1 === currentStep ? "active" : ""}
          >
            <span class="nav-step-num">{idx + 1}</span>
            <span class="nav-step-title">
              {navItem.title || navItem.question || `Stap ${idx + 1}`}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<div class="page-shell" style={`--color-accent: ${accentColor}`}>
  <aside class="sidebar-left" aria-label="Navigatiemenu"></aside>

  <main
    class="content-col"
    data-step-id={String(currentStep)}
    data-category={categorySlug}
  >
    <header class="page-header">
      <a href="/index.html" class="back-button"> Dashboard </a>
      <p class="category-pill">{category}</p>
      <button
        class="hamburger-btn"
        id="hamburgerBtn"
        aria-label="Open vragennavigatie"
      >
        {currentStep}<span class="step-total">/{totalSteps}</span>
      </button>
    </header>

    <section class="card">
      {item.title && <h1 class="card-title">{item.title}</h1>}
      {item.subtitle && <p class="card-subtitle">{item.subtitle}</p>}
      {item.text && <p class="card-body">{item.text}</p>}

      {item.source && (
        <p class="card-source">
          <span class="source-label">Bron</span>
          {item.source}
        </p>
      )}

      {item.type === "video" && embedUrl && embedUrl.trim() !== "" && (
        <div class="video-wrapper">
          <iframe
            src={embedUrl}
            title={item.title}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>
      )}

      {item.type === "question" && (
        <div class="question-block">
          {item.question && <h2 class="question-text">{item.question}</h2>}
          {item.description && <p class="card-body">{item.description}</p>}
          {item.label && <label class="field-label">{item.label}</label>}

          {item.input_type === "text" && (
            <input class="text-input" type="text" placeholder={item.placeholder || "Typ hier je antwoord"} />
          )}

          {item.input_type === "email" && (
            <input class="text-input" type="email" placeholder="Typ hier je e-mailadres" />
          )}

          {item.input_type === "long_text" && (
            <textarea class="text-area" rows="5" placeholder={item.placeholder || "Typ hier je antwoord"} />
          )}

          {item.input_type === "single_choice" && (
            <ul class="options-list" role="radiogroup">
              {options.map((option, index) => {
                const text = typeof option === "string" ? option : option.text;
                return (
                  <li>
                    <label class="option-label">
                      <input type="radio" name={item.id} value={text} class="option-input" />
                      <span class="option-key">{String.fromCharCode(65 + index)}</span>
                      <span class="option-text">{text}</span>
                    </label>
                  </li>
                );
              })}
            </ul>
          )}

          {item.input_type === "multiple_choice" && (
            <div data-multiple-choice>
              <p class="mc-hint">Selecteer maximaal 2 opties</p>
              <ul class="options-list" role="group">
                {options.map((option, index) => {
                  const text = typeof option === "string" ? option : option.text;
                  return (
                    <li>
                      <label class="option-label">
                        <input
                          type="checkbox"
                          name={item.id}
                          value={text}
                          class="option-input"
                        />
                        <span class="option-key">
                          {String.fromCharCode(65 + index)}
                        </span>
                        <span class="option-text">{text}</span>
                      </label>
                    </li>
                  );
                })}
              </ul>
              <div
                class="mc-error"
                role="alert"
                aria-live="polite"
                id="mc-error"
                hidden
              >
                Je kunt maximaal 2 opties selecteren.
              </div>
            </div>
          )}

          {item.input_type === "rating" && (
            <div class="rating-block">
              {scale.min_label && (
                <span class="rating-label">{scale.min_label}</span>
              )}
              <div class="rating-row">
                {ratings.map((ratingValue) => (
                  <label class="rating-option">
                    <input
                      type="radio"
                      id={`rating-${item.id}-${ratingValue}`}
                      name={`rating-${item.id}`}
                      value={ratingValue}
                      class="option-input"
                    />
                    <span class="rating-pip">{ratingValue}</span>
                  </label>
                ))}
              </div>
              {scale.max_label && (
                <span class="rating-label">{scale.max_label}</span>
              )}
            </div>
          )}

          {item.input_type === "sentence_completion" && (
            <div class="sentence-completion-block">
              <textarea
                class="text-area"
                rows="4"
                name={item.id}
                placeholder={item.placeholder || "Vul je antwoord aan"}
                required={item.required}
              />
            </div>
          )}

          {item.input_type === "matching" && (
            <div class="matching-block" data-matching data-question-id={item.id}>
              <div class="matching-grid">
                {(item.pairs || []).map((pair, index) => (
                  <div class="matching-row">
                    <div class="matching-prompt">
                      <span class="option-key">{String.fromCharCode(65 + index)}</span>
                      <span>{pair.prompt}</span>
                    </div>
                    <select
                      class="matching-select"
                      name={`${item.id}-${index}`}
                      required={item.required}
                    >
                      <option value="">Kies een antwoord</option>
                      {(item.pairs || []).map((answerPair) => (
                        <option value={answerPair.answer}>{answerPair.answer}</option>
                      ))}
                    </select>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {
        item.id?.endsWith("_submit") && (
          <div class="action-row">
            <a href="/index.html" class="btn btn--ghost">
              Dashboard
            </a>
            {nextSectionUrl && (
              <a href={nextSectionUrl} class="btn btn--primary">
                Volgend deel
              </a>
            )}
          </div>
        )
      }
    </section>

    <nav class="bottom-nav" aria-label="Navigatie">
      {
        previousPage ? (
          <a class="nav-btn nav-btn--prev" href={previousPage}>
            {" "}
            Vorige
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled" aria-disabled="true">
            {" "}
            Vorige
          </span>
        )
      }

      {
        nextPage ? (
          <a class="nav-btn nav-btn--next" href={nextPage} id="nav-next">
            Volgende{" "}
          </a>
        ) : (
          <span class="nav-btn nav-btn--disabled" aria-disabled="true">
            Volgende{" "}
          </span>
        )
      }
    </nav>
  </main>

  <aside class="sidebar-right" aria-hidden="true"></aside>
</div>

<script>
  // @ts-nocheck
  import { supabase } from "../../lib/supabase";

  const main = document.querySelector("main.content-col");
  const navNext = document.getElementById("nav-next");

  const stepId = main?.dataset.stepId;
  const category = main?.dataset.category;
  const startedAt = new Date();

  let alreadySaved = false;

  async function saveProgress() {
    if (alreadySaved) return;
    if (!stepId || !category) return;

    alreadySaved = true;

    const endedAt = new Date();
    const durationSeconds = Math.round((endedAt - startedAt) / 1000);

    const {
      data: { user },
    } = await supabase.auth.getUser();

    const response = await fetch("/api/track-step", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        userId: user?.id || "anonymous",
        email: user?.email || null,
        name: user?.user_metadata?.name || null,
        stepId,
        category,
        startedAt: startedAt.toISOString(),
        endedAt: endedAt.toISOString(),
        durationSeconds,
      }),
    });

    const result = await response.json();
  }

  if (navNext) {
    navNext.addEventListener("click", async (e) => {
      e.preventDefault();
      await saveProgress();
      window.location.href = navNext.href;
    });
  }

  const mcBlock = document.querySelector("[data-multiple-choice]");

  if (mcBlock) {
    const checkboxes = mcBlock.querySelectorAll("input[type='checkbox']");
    const errorEl = document.getElementById("mc-error");

    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", (e) => {
        const checked = [...checkboxes].filter((cb) => cb.checked);

        if (checked.length > 2) {
          e.target.checked = false;

          if (errorEl) {
            errorEl.hidden = false;
            clearTimeout(errorEl._timer);
            errorEl._timer = setTimeout(() => {
              errorEl.hidden = true;
            }, 3000);
          }
        } else {
          if (errorEl) errorEl.hidden = true;
        }
      });
    });
  }

  // ── Hamburger nav ──────────────────────────────────────────────
  const hamburgerBtn = document.getElementById("hamburgerBtn");
  const navPanel = document.getElementById("navPanel");
  const navOverlay = document.getElementById("navOverlay");
  const navCloseBtn = document.getElementById("navCloseBtn");

  function openNav() {
    navPanel?.classList.add("open");
    navOverlay?.classList.add("open");
    hamburgerBtn?.classList.add("open");
    hamburgerBtn?.setAttribute("aria-expanded", "true");
  }

  function closeNav() {
    navPanel?.classList.remove("open");
    navOverlay?.classList.remove("open");
    hamburgerBtn?.classList.remove("open");
    hamburgerBtn?.setAttribute("aria-expanded", "false");
  }

  hamburgerBtn?.addEventListener("click", () =>
    navPanel?.classList.contains("open") ? closeNav() : openNav(),
  );
  navCloseBtn?.addEventListener("click", closeNav);
  navOverlay?.addEventListener("click", closeNav);

  // ── Accessibility simulator ────────────────────────────────────

  const a11yFab     = document.getElementById("a11yFab");
  const a11yPanel   = document.getElementById("a11yPanel");
  const a11yDot     = document.getElementById("a11yActiveDot");
  const a11yReset   = document.getElementById("a11yReset");

  // Toggle panel open/close
  a11yFab?.addEventListener("click", () => {
    const isOpen = !a11yPanel.hidden;
    a11yPanel.hidden = isOpen;
    a11yFab.setAttribute("aria-expanded", String(!isOpen));
  });

  // ── State ──────────────────────────────────────────────────────
  const sim = {
    contrast: 100, brightness: 100, blur: 0,
    colorblind: "none", dyslexia: 0, tremor: 0, cursorDelay: 0,
  };

  const colorblindMap = {
    none: "",
    "cb-protanopia":    "url(#cb-protanopia)",
    "cb-deuteranopia":  "url(#cb-deuteranopia)",
    "cb-tritanopia":    "url(#cb-tritanopia)",
    "cb-achromatopsia": "url(#cb-achromatopsia)",
  };

  // Apply all simulation values to <html>
  function applyAll() {
    const root = document.documentElement;

    // CSS filter on <html> (contrast + brightness + blur + colour-blindness)
    let f = "";
    if (sim.contrast   !== 100) f += `contrast(${sim.contrast}%) `;
    if (sim.brightness !== 100) f += `brightness(${sim.brightness}%) `;
    if (sim.blur        > 0)    f += `blur(${sim.blur}px) `;
    if (sim.colorblind !== "none") f += colorblindMap[sim.colorblind];
    root.style.filter = f.trim();

    // Active indicator dot
    const active =
      sim.contrast !== 100 || sim.brightness !== 100 || sim.blur > 0 ||
      sim.colorblind !== "none" || sim.dyslexia > 0 || sim.tremor > 0 || sim.cursorDelay > 0;
    if (a11yDot) a11yDot.hidden = !active;
  }

  // ── Colour scheme ──────────────────────────────────────────────
  function setColorScheme(val) {
    if (val === "system") {
      const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.setAttribute("data-color-scheme", dark ? "dark" : "light");
    } else {
      document.documentElement.setAttribute("data-color-scheme", val);
    }
  }

  // ── Dyslexia (from leraar's code) ─────────────────────────────
  let textNodes = [];
  let dyslexiaInterval = null;

  function findTextNodes() {
    textNodes = [];
    const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
    while (walker.nextNode()) {
      const node = walker.currentNode;
      if (node.nodeValue.trim() && !node.parentElement?.closest(".a11y-fab-wrap")) {
        const words = [];
        let re = /\w+/g, m;
        while ((m = re.exec(node.nodeValue)) !== null)
          words.push({ pos: m.index, len: m[0].length });
        textNodes.push({ node, words, original: node.nodeValue });
      }
    }
  }

  function messUpWords(chance, tempo) {
    clearInterval(dyslexiaInterval);
    if (chance === 0) {
      textNodes.forEach((t) => (t.node.nodeValue = t.original));
      return;
    }
    dyslexiaInterval = setInterval(() => {
      textNodes.forEach((t) => {
        let val = t.original;
        t.words.forEach((w) => {
          if (Math.random() < chance && w.len > 3) {
            const word = val.slice(w.pos, w.pos + w.len);
            const mid = word.slice(1, -1).split("");
            for (let i = mid.length - 1; i > 0; i--) {
              const j = Math.floor(Math.random() * (i + 1));
              [mid[i], mid[j]] = [mid[j], mid[i]];
            }
            val =
              val.slice(0, w.pos) +
              word[0] + mid.join("") + word[word.length - 1] +
              val.slice(w.pos + w.len);
          }
        });
        t.node.nodeValue = val;
      });
    }, tempo);
  }

  const dyslexiaConfig = { 0:[0,0], 1:[0.1,250], 2:[0.2,100], 3:[0.3,40], 4:[1,1] };

  // ── Tremor ─────────────────────────────────────────────────────
  let tremorInterval = null;

  function setTremor(val) {
    clearInterval(tremorInterval);
    document.body.style.transform = "";
    if (val === 0) return;
    tremorInterval = setInterval(() => {
      const x = ((Math.random() - 0.5) * val * 6).toFixed(1);
      const y = ((Math.random() - 0.5) * val * 6).toFixed(1);
      document.body.style.transform = `translate(${x}px, ${y}px)`;
    }, 80);
  }

  // ── Cursor delay (motorieke beperking) ────────────────────────
  const cursorDot = document.getElementById("a11yCursorDot");

  function followCursor(e) {
    document.body.style.setProperty("--client-x", e.clientX);
    document.body.style.setProperty("--client-y", e.clientY);
  }

  function setCursorDelay(seconds) {
    sim.cursorDelay = seconds;
    if (seconds === 0) {
      document.body.removeEventListener("pointermove", followCursor);
      document.body.classList.remove("cursor-delayed");
      if (cursorDot) cursorDot.style.transition = "";
    } else {
      document.body.addEventListener("pointermove", followCursor);
      document.body.classList.add("cursor-delayed");
      if (cursorDot) cursorDot.style.transition = `translate ${seconds}s ease-in`;
    }
    applyAll();
  }


  function makeSlider(id, valId, key, suffix, decimals) {
    const el  = document.getElementById(id);
    const out = document.getElementById(valId);
    if (!el || !out) return;
    el.addEventListener("input", () => {
      const v = parseFloat(el.value);
      sim[key] = v;
      out.textContent = decimals ? v.toFixed(decimals) + suffix : Math.round(v) + suffix;
      if (key === "tremor") setTremor(v);
      applyAll();
    });
  }

  makeSlider("contrastRange",    "contrastVal",    "contrast",    "%",  0);
  makeSlider("brightnessRange",  "brightnessVal",  "brightness",  "%",  0);
  makeSlider("blurRange",        "blurVal",        "blur",        "",   1);
  makeSlider("tremorRange",      "tremorVal",      "tremor",      "",   1);

  // ── Radio group helper ─────────────────────────────────────────
  function makeRadioGroup(id, key, onChange) {
    document.querySelectorAll(`#${id} .a11y-chip`).forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(`#${id} .a11y-chip`).forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        sim[key] = btn.dataset.val;
        if (onChange) onChange(btn.dataset.val);
        applyAll();
      });
    });
  }

  makeRadioGroup("schemeGroup",     "scheme",     setColorScheme);
  makeRadioGroup("colorblindGroup", "colorblind");
  makeRadioGroup("dyslexiaGroup", "dyslexia", (val) => {
    findTextNodes();
    const [chance, tempo] = dyslexiaConfig[val];
    messUpWords(chance, tempo);
  });
  makeRadioGroup("cursorDelayGroup", "cursorDelay", (val) => {
    setCursorDelay(parseFloat(val));
  });

  // ── Reset ──────────────────────────────────────────────────────
  a11yReset?.addEventListener("click", () => {
    Object.assign(sim, {
      contrast: 100, brightness: 100, blur: 0,
      colorblind: "none", dyslexia: 0, tremor: 0, cursorDelay: 0,
    });

    [
      ["contrastRange",    "contrastVal",    100,  "%"],
      ["brightnessRange",  "brightnessVal",  100,  "%"],
      ["blurRange",        "blurVal",        0,    ""],
      ["tremorRange",      "tremorVal",      0,    ""],
    ].forEach(([rid, vid, val, suf]) => {
      const el = document.getElementById(rid);
      const out = document.getElementById(vid);
      if (el)  el.value = val;
      if (out) out.textContent = val + suf;
    });

    ["colorblindGroup","cursorDelayGroup","dyslexiaGroup","schemeGroup"].forEach((gid) => {
      document.querySelectorAll(`#${gid} .a11y-chip`).forEach((b, i) =>
        b.classList.toggle("active", i === 0)
      );
    });

    clearInterval(dyslexiaInterval);
    setTremor(0);
    setCursorDelay(0);
    textNodes.forEach((t) => (t.node.nodeValue = t.original));
    document.documentElement.removeAttribute("data-color-scheme");
    applyAll();
  });

  // Init
  findTextNodes();
</script>

