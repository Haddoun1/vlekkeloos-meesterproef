}

.rating-block {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.rating-label {
  font-family: var(--font-light);
  font-size: var(--size-sm);
  opacity: 0.6;
}

.rating-row {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.rating-option {
  cursor: pointer;
}

.rating-option .option-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.rating-pip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.8rem;
  height: 2.8rem;
