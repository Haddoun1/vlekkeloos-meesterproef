}

.text-input:focus,
.text-area:focus {
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 30%, transparent);
}

.mc-hint {
  font-family: var(--font-light);
  font-size: var(--size-sm);
  opacity: 0.55;
  margin: 0;
}

.options-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.option-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 0;
  height: 0;
}

.option-label {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.7rem 1rem 0.7rem 0.75rem;
  border: 1.5px solid rgba(0,0,0,0.1);
  border-radius: 12px;
  background: rgba(255,255,255,0.5);
  cursor: pointer;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    transform 0.12s ease,
    box-shadow 0.18s ease;
  user-select: none;
  position: relative;
}

.option-label:hover {
  background: rgba(255,255,255,0.9);
  border-color: rgba(0,0,0,0.22);
  transform: translateX(3px);
  box-shadow: 0 2px 8px rgba(0,0,0,0.07);
}

.option-label:active {
  transform: translateX(2px) scale(0.995);
}

.option-label:has(.option-input:checked) {
  background: color-mix(in srgb, var(--color-accent) 50%, white);
  border-color: rgba(0,0,0,0.3);
  box-shadow: 0 2px 12px color-mix(in srgb, var(--color-accent) 40%, transparent);
}

.option-label:has(.option-input:checked) .option-key {
  background: var(--color-text);
