---
// @ts-nocheck
import data from "../../data/mensenkennersvragen.json";
import { slugify } from "../../utils/slugify";

export async function getStaticPaths() {
  const items = data.blocks.filter(
    (item) =>
      item.Category && ["content", "video", "question"].includes(item.type),
  );

  return items.map((item) => {
    const categorySlug = slugify(item.Category);

    const categoryItems = items.filter(
      (x) => slugify(x.Category) === categorySlug,
    );

    const stepIndex = categoryItems.findIndex((x) => x.id === item.id);

    return {
      params: {
        category: categorySlug,
        step: String(stepIndex + 1),
      },
      props: {
        item,
        currentStep: stepIndex + 1,
        totalSteps: categoryItems.length,
        category: item.Category,
      },
    };
  });
}

const { item, currentStep, totalSteps, category } = Astro.props;

const categorySlug = slugify(category);

const previousPage =
  currentStep > 1 ? `/${categorySlug}/${currentStep - 1}` : null;

const nextPage =
  currentStep < totalSteps ? `/${categorySlug}/${currentStep + 1}` : null;

let embedUrl = item.url;

if (item.url?.includes("vimeo.com")) {
  const id = item.url.split("/").filter(Boolean).pop()?.split("?")[0];
  embedUrl = `https://player.vimeo.com/video/${id}`;
}

if (item.url?.includes("youtube.com/watch?v=")) {
  const id = item.url.split("v=")[1]?.split("&")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

if (item.url?.includes("youtu.be/")) {
  const id = item.url.split("youtu.be/")[1]?.split("?")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

const options = item.options || [];
const scale = item.scale || {};
const minRating = scale.min || 1;
const maxRating = scale.max || 10;
const ratings = Array.from(
  { length: maxRating - minRating + 1 },
  (_, i) => minRating + i,
);

let nextSectionUrl = null;

if (item.id?.endsWith("_submit")) {
  if (item.id === "intro_submit") {
    nextSectionUrl = "/deel-1/1";
  }

  if (item.id === "d1_submit") {
    nextSectionUrl = "/deel-2/1";
  }

  if (item.id === "d2_submit") {
    nextSectionUrl = "/deel-3/1";
  }
}
---

<link rel="stylesheet" href="/styles/global.css" />

<main>
  <h1>{category} - Stap {currentStep} van {totalSteps}</h1>

  <section>
    {item.title && <h2>{item.title}</h2>}

    {item.subtitle && <p>{item.subtitle}</p>}

    {item.text && <p>{item.text}</p>}

    {
      item.source && (
        <p>
          <strong>Bron:</strong> {item.source}
        </p>
      )
    }

    {
      item.type === "video" && embedUrl && (
        <iframe
          width="100%"
          height="500"
          src={embedUrl}
          title={item.title}
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        />
      )
    }

    {
      item.type === "question" && (
        <>
          {item.question && <h3>{item.question}</h3>}

          {item.description && <p>{item.description}</p>}

          {item.label && <label>{item.label}</label>}

          {item.input_type === "text" && (
            <input
              type="text"
              placeholder={item.placeholder || "Typ hier je antwoord"}
            />
          )}

          {item.input_type === "email" && (
            <input type="email" placeholder="Typ hier je e-mailadres" />
          )}

          {item.input_type === "long_text" && (
            <textarea
              rows="6"
              placeholder={item.placeholder || "Typ hier je antwoord"}
            />
          )}

          {item.input_type === "single_choice" && (
            <ul class="options">
              {options.map((option, index) => {
                const text = typeof option === "string" ? option : option.text;

                return (
                  <li>
                    <label class="option">
                      <input type="radio" name={item.id} value={text} />

                      <span class="spanOption">
                        {String.fromCharCode(65 + index)}
                      </span>

                      <span class="option-text">{text}</span>
                    </label>
                  </li>
                );
              })}
            </ul>
          )}

          {item.input_type === "multiple_choice" && (
            <ul class="options">
              {options.map((option, index) => {
                const text = typeof option === "string" ? option : option.text;

                return (
                  <li>
                    <label class="option">
                      <input type="checkbox" name={item.id} value={text} />
                      <span class="spanOption">
                        {String.fromCharCode(65 + index)}
                      </span>
                      <span class="option-text">{text}</span>
                    </label>
                  </li>
                );
              })}
            </ul>
          )}

          {item.input_type === "rating" && (
            <div>
              {scale.min_label && <span>{scale.min_label}</span>}

              {ratings.map((ratingValue) => (
                <div>
                  <input
                    type="radio"
                    id={`rating-${item.id}-${ratingValue}`}
                    name={`rating-${item.id}`}
                    value={ratingValue}
                  />
                  <label for={`rating-${item.id}-${ratingValue}`}>
                    {ratingValue}
                  </label>
                </div>
              ))}

              {scale.max_label && <span>{scale.max_label}</span>}
            </div>
          )}
        </>
      )
    }

    {
      item.id?.endsWith("_submit") && (
        <div class="submit-navigation">
          <a href="/index.html" class="backToMenu">
            Terug naar dashboard
          </a>

          {nextSectionUrl && (
            <a href={nextSectionUrl} class="nextPart">
              Naar volgend deel
            </a>
          )}
        </div>
      )
    }

    {
      item.id?.endsWith("_end") && (
        <div class="submit-navigation">
          <a href="/index.html" class="backToMenu">
            Terug naar dashboard
          </a>
        </div>
      )
    }
  </section>

  <nav>
    {
      previousPage && (
        <a class="nav-prev" href={previousPage}>
          Vorige
        </a>
      )
    }

    {
      nextPage && (
        <a class="nav-next" href={nextPage}>
          Volgende
        </a>
      )
    }
  </nav>
  <link rel="stylesheet" href="/styles/global.css" />
</main>

<style>
  body {
    background: var(--gradient-bg-cyan);
  }

  main {
    width: min(70ch, calc(100% - 2rem));
    margin-inline: auto;
  }

  h1 {
    font-family: var(--font-extra-bold);
    font-size: var(--size-5xl);
    margin: 7rem 0 0 1rem;
  }

  h2 {
    font-family: var(--font-semi-bold);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    margin: 1rem 0 0 1rem;
  }

  h3 {
    font-family: var(--font-semi-bold);
    font-size: var(--size-xl);
    margin: 1rem 0 0 1rem;
  }

  p {
    font-size: var(--size-xl);
    line-height: 1.2;
    margin: 4rem 0 0 1rem;
    color: var(--color-text);
  }

  li {
    list-style: none;
    margin: 0 0 0 1rem;
  }

  li:first-child {
    margin-top: 1rem;
  }

  button {
    margin: 0.5rem 0 0 0;
    font-family: var(--font-semi-bold);
    padding: 0.75rem 1.5rem;
    width: 60%;
    border: 2px solid black;
    border-radius: 4px;
    background: var(--color-background);
    cursor: pointer;
    text-align: left;
  }

  input[type="text"],
  input[type="email"] {
    margin: 1rem 0 0 1rem;
    padding: 0.75rem;
    width: calc(100% - 2rem);
    border: 2px solid black;
    border-radius: 4px;
  }

  textarea {
    margin: 1rem 0 0 1rem;
    padding: 0.75rem;
    width: calc(100% - 2rem);
    border: 2px solid black;
    border-radius: 4px;
    font-family: var(--font-light);
  }

  span {
    font-family: var(--font-light);
  }

  div {
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    gap: 0.5rem;
  }

  iframe {
    align-self: center;
    margin: 2rem 0 0 0;
    border: 2px solid black;
    border-radius: 4px;
    width: 40em;
    height: 23em;
  }

  .nav-prev,
  .nav-next,
  .backToMenu,
  .nextPart {
    position: fixed;
    top: 90%;
    transform: translateY(-50%);
    font-family: var(--font-bold);
    padding: var(--size-xs) var(--size-2xl);
    border: none;
    border-radius: 25px;
    background: var(--color-background);
    text-decoration: none;
    background-color: var(--color-cyan);
    color: var(--color-text);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
    font-size: var(--size-lg);
  }

  .nav-prev {
    left: calc(55% - 400px - 5rem);
  }

  .nav-next {
    right: calc(55% - 400px - 5rem);
  }

  .options {
    padding: 0;
  }

  .options li {
    list-style: none;
    margin: 0.5rem 0;
  }

  .option {
    display: flex;
    align-items: center;
    justify-self: stretch;
    gap: 1rem;
    background-color: rgba(0, 0, 0, 0.081);
    color: var(--color-text);
    border: 1px solid rgba(0, 0, 0, 0.062);
    border-radius: 8px;
    padding: 0.5rem;
    font-size: var(--size-base);
    font-family: var(--font-semi-bold);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: left;
    margin: 0 1rem 0.5rem 1rem;
  }

  .option:hover {
    transform: scale(1.01);
  }

  .option input {
    display: none;
  }

  .option-text {
    flex: 1;
  }

  .option:has(input:checked) {
    background: var(--color-cyan);
    border-color: var(--color-cyan);
  }

  .spanOption {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    border-radius: 6px;
    background-color: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.1);
    font-size: var(--size-sm);
  }
</style>
