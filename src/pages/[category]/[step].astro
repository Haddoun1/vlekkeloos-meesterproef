---
// @ts-nocheck
import data from "../../data/mensenkennersvragen.json";
import { slugify } from "../../utils/slugify";

export async function getStaticPaths() {
  const items = data.blocks.filter(
    (item) =>
      item.Category &&
      ["content", "video", "question"].includes(item.type)
  );

  return items.map((item) => {
    const categorySlug = slugify(item.Category);

    const categoryItems = items.filter(
      (x) => slugify(x.Category) === categorySlug
    );

    const stepIndex = categoryItems.findIndex((x) => x.id === item.id);

    return {
      params: {
        category: categorySlug,
        step: String(stepIndex + 1),
      },
      props: {
        item,
        currentStep: stepIndex + 1,
        totalSteps: categoryItems.length,
        category: item.Category,
      },
    };
  });
}

const { item, currentStep, totalSteps, category } = Astro.props;

const categorySlug = slugify(category);

const previousPage =
  currentStep > 1 ? `/${categorySlug}/${currentStep - 1}` : null;

const nextPage =
  currentStep < totalSteps ? `/${categorySlug}/${currentStep + 1}` : null;

let embedUrl = item.url;

if (item.url?.includes("vimeo.com")) {
  const id = item.url.split("/").filter(Boolean).pop()?.split("?")[0];
  embedUrl = `https://player.vimeo.com/video/${id}`;
}

if (item.url?.includes("youtube.com/watch?v=")) {
  const id = item.url.split("v=")[1]?.split("&")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

if (item.url?.includes("youtu.be/")) {
  const id = item.url.split("youtu.be/")[1]?.split("?")[0];
  embedUrl = `https://www.youtube.com/embed/${id}`;
}

const options = item.options || [];
const scale = item.scale || {};
const minRating = scale.min || 1;
const maxRating = scale.max || 10;
const ratings = Array.from(
  { length: maxRating - minRating + 1 },
  (_, i) => minRating + i
);

let nextSectionUrl = null;

if (item.id?.endsWith("_submit")) {
  if (item.id === "intro_submit") {
    nextSectionUrl = "/deel-1/1";
  }

  if (item.id === "d1_submit") {
    nextSectionUrl = "/deel-2/1";
  }

  if (item.id === "d2_submit") {
    nextSectionUrl = "/deel-3/1";
  }
}


---
<main>
<h1>{category} - Stap {currentStep} van {totalSteps}</h1>

<section>
  {item.title && <h2>{item.title}</h2>}

  {item.subtitle && <p>{item.subtitle}</p>}

  {item.text && <p>{item.text}</p>}

  {item.source && <p><strong>Bron:</strong> {item.source}</p>}

  {item.type === "video" && embedUrl && (
    <iframe
      width="100%"
      height="500"
      src={embedUrl}
      title={item.title}
      frameborder="0"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>
  )}

  {item.type === "question" && (
    <>
      {item.question && <h3>{item.question}</h3>}

      {item.description && <p>{item.description}</p>}

      {item.label && <label>{item.label}</label>}

      {item.input_type === "text" && (
        <input type="text" placeholder={item.placeholder || "Typ hier je antwoord"} />
      )}

      {item.input_type === "email" && (
        <input type="email" placeholder="Typ hier je e-mailadres" />
      )}

      {item.input_type === "long_text" && (
        <textarea
          rows="6"
          placeholder={item.placeholder || "Typ hier je antwoord"}
        ></textarea>
      )}

      {item.input_type === "single_choice" && (
        <ul>
          {options.map((option) => (
            <li>
              <button type="button">
                {typeof option === "string" ? option : option.text}
              </button>
            </li>
          ))}
        </ul>
      )}

      {item.input_type === "multiple_choice" && (
        <ul>
          {options.map((option) => (
            <li>
              <button type="button">
                {typeof option === "string" ? option : option.text}
              </button>
            </li>
          ))}
        </ul>
      )}

      {item.input_type === "rating" && (
        <div>
          {scale.min_label && <span>{scale.min_label}</span>}

          {ratings.map((ratingValue) => (
            <div>
              <input
                type="radio"
                id={`rating-${item.id}-${ratingValue}`}
                name={`rating-${item.id}`}
                value={ratingValue}
              />
              <label for={`rating-${item.id}-${ratingValue}`}>
                {ratingValue}
              </label>
            </div>
          ))}

          {scale.max_label && <span>{scale.max_label}</span>}
        </div>
      )}
    </>
  )}

{item.id?.endsWith("_submit") && (
  <div class="submit-navigation">
    
    <a href="/index.html" class="button">
      Terug naar dashboard
    </a>

    {nextSectionUrl && (
      <a href={nextSectionUrl} class="button button-primary">
        Naar volgend deel
      </a>
    )}
  </div>
)}

{item.id?.endsWith("_end") && (
  <div class="submit-navigation">
    
    <a href="/index.html" class="button">
      Terug naar dashboard
    </a>

  </div>
)}

</section>

<nav>
  {previousPage && <a href={previousPage}>Vorige</a>}

  {nextPage && <a href={nextPage}>Volgende</a>}
</nav>
<link rel="stylesheet" href="/styles/global.css" />
</main>

<style>
  :global(body) {
    color: var(--color-text);
    background-color: var(--color-green);
  }

  :global(main) {
    display: grid;
    grid-template-columns: 1fr minmax(0, 800px) 1fr;
  }

  :global(main > *) {
    grid-column: 2;
  }

  :global(main h1) {
    font-size: var(--size-4xl);
    font-family: var(--font-bold);
    margin: clamp(6rem, 1vw, 1rem) 0rem clamp(1rem, 1vw, 3rem) 1rem;
  }

  :global(main h2) {
    font-family: var(--font-semi-bold);
    margin: 1rem 0rem 3rem 1rem;
  }

  :global(main h3) {
    font-size: var(--size-2xl);
    font-family: var(--font-semi-bold);
    margin: 1rem 0rem 1rem 1rem;
  }
  :global(main p) {
    font-family: var(--font-light);
    margin: 3rem 0rem 3rem 1rem;
  }

  :global(input),
  :global(textarea) {
    width: 100%;
    box-sizing: border-box;

    padding: 1rem;
    margin-left: 1rem;

    border: none;
    border-radius: 1rem;

    background-color: var(--color-background);
    color: var(--color-text);

    font-family: var(--font-light);
    font-size: 1rem;
  }

  :global(textarea) {
    resize: vertical;
    min-height: 10rem;
  }

  :global(ul) {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    list-style: none;
    padding: 0;
    margin: 0 0 0 1rem;
  }

  :global(li) {
    width: 100%;
  }

  :global(button) {
    width: 100%;

    padding: 1rem;

    border: none;
    border-radius: 1rem;

    background-color: var(--color-background);
    color: var(--color-text);

    font-family: var(--font-semi-bold);
    font-size: 1rem;

    cursor: pointer;
    transition: transform 0.2s ease;
  }

  :global(button:hover) {
    transform: scale(1.02);
  }

  :global(nav) {
    display: flex;
    justify-content: space-between;
    gap: 1rem;

    margin: 4rem 1rem;
  }

  :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 1rem 2rem;

    border-radius: 999rem;

    background-color: var(--color-background);
    color: var(--color-text);

    text-decoration: none;
    font-family: var(--font-semi-bold);
  }

  :global(iframe) {
    border-radius: 1rem;
    margin-left: 1rem;
  }

  :global(label) {
    font-family: var(--font-semi-bold);
  }

  :global(input[type="radio"]) {
    accent-color: var(--color-text);
  }

  :global(div:has(input[type="radio"])) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(div:has(input[type="radio"])):not(:last-child) {
    margin-bottom: 0.75rem;
  }
</style>
