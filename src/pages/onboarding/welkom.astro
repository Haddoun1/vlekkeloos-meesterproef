---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
---

<MainLayout
  title="Welkom"
  nextHref="/onboarding/login"
  headingText="Welkom bij Mensenkenners!"
  bodyText="We gaan je een aantal vragen stellen om je ervaring zo persoonlijk mogelijk te maken."
  step={1}
  totalSteps={5}
  showBack={false}
  showProgress={false}
  variant="welkom"
>
  <div class="loader">
    <img
      src="/images/Mensenkenners-horizontaal-w.png"
      alt="Mensenkenners logo"
    />
  </div>

  <img
    class="mockup"
    src="/images/mockupmensenkenners.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<script>
  // @ts-nocheck
  const loader = document.querySelector(".loader");

  if (loader) {
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    window.addEventListener("load", () => {
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReduced) {
        loader.classList.add("hidden");
      } else if (isMobile) {
        setTimeout(() => {
          loader.classList.add("hidden-mobile");
        }, 750);
      } else {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            loader.classList.add("revealed");
          });
        });
      }
    });
  }
</script>
