---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionMulti from "../../components/QuestionMulti.astro";
---

<MainLayout
  title="Stap 5"
  nextHref="/onboarding/step-6"
  backHref="/onboarding/step-4"
  headingText="Ervaring"
  bodyText="Met welke groepen heb je ervaring?"
  step={5}
  totalSteps={9}
>
  <QuestionMulti
    slot="question"
    name="ervaring_groepen"
    options={[
      "Visuele beperking",
      "Auditieve beperking",
      "Motorische beperking",
      "Niet-zichtbare beperking",
      "Verstandelijke beperking",
      "Psychische aandoening",
      "Geen ervaring",
    ]}
  />

  <img class="mockup"
    src="../../public/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<style>
  :global(.panel-left) {
    display: none !important;
  }

  :global(.panel-right) {
    margin: 2em 0 auto 0;
    height: 100%;
  }

  @media (min-width: 768px) {
    :global(.panel-left) {
      display: flex !important;
    }

    :global(.panel-right) {
        margin: 0 auto;
        height: 100%;
    }
  }

  .mockup{
    max-width: 400px !important;
  }
</style>