---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<!-- nextHref="/onboarding/result" -->

<MainLayout
  title="Stap 9"
  nextHref="/"
  backHref="/onboarding/step-8"
  headingText="Houding"
  bodyText="Welke uitspraak past het best bij jou?"
  step={9}
  totalSteps={9}
>
  <QuestionSingle
    slot="question"
    name="houding"
    options={[
      "Iedereen hetzelfde",
      "Rekening houden",
      "Niet altijd zeker hoe",
      "Ongemakkelijk",
    ]}
  />

  <img class="mockup"
    src="../../public/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<style>
  :global(.panel-left) {
    display: none !important;
  }

  :global(.panel-right) {
    margin: 2em 0 auto 0;
    height: 100%;
  }

  @media (min-width: 768px) {
    :global(.panel-left) {
      display: flex !important;
    }

    :global(.panel-right) {
        margin: 0 auto;
        height: 100%;
    }
  }

  .mockup{
    max-width: 400px !important;
  }
</style>
