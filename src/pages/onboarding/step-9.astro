---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<!-- nextHref="/onboarding/result" -->

<MainLayout
  title="Stap 9"
  nextHref="/"
  backHref="/onboarding/step-8"
  headingText="Houding"
  bodyText="Welke uitspraak past het best bij jou?"
  step={9}
  totalSteps={9}
  stepId="onboarding_step-9"
  category="onboarding"
  variant="steps-quiz"
>
  <QuestionSingle
    slot="question"
    name="houding"
    options={[
      "Iedereen hetzelfde",
      "Rekening houden",
      "Niet altijd zeker hoe",
      "Ongemakkelijk",
    ]}
  />

  <img class="mockup"
    src="/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>