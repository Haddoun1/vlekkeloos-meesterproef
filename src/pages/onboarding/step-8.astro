---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<MainLayout
  title="Stap 8"
  nextHref="/onboarding/step-9"
  backHref="/onboarding/step-7"
  headingText="Kennis"
  bodyText="Een dove klant wil iets bestellen. Wat doe je?"
  step={8}
  totalSteps={9}
  stepId="onboarding_step-8"
  category="onboarding"
>
  <QuestionSingle
    slot="question"
    name="auditieve_beperking"
    options={[
      "Harder praten",
      "Schrijven of typen",
      "Gebarentaal",
      "Ik weet het niet",
    ]}
  />

  <img class="mockup"
    src="../../public/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<style>
  :global(.panel-left) {
    display: none !important;
  }

  :global(.panel-right) {
    margin: 2em 0 auto 0;
    height: 100%;
  }

  @media (min-width: 768px) {
    :global(.panel-left) {
      display: flex !important;
    }

    :global(.panel-right) {
        margin: 0 auto;
        height: 100%;
    }
  }

  .mockup{
    max-width: 400px !important;
  }
</style>
