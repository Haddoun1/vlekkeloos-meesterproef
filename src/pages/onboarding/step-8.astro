---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<MainLayout
  title="Stap 8"
  nextHref="/onboarding/step-9"
  backHref="/onboarding/step-7"
  headingText="Kennis"
  bodyText="Een dove klant wil iets bestellen. Wat doe je?"
  step={8}
  totalSteps={9}
  stepId="onboarding_step-8"
  category="onboarding"
  variant="steps-quiz"
>
  <QuestionSingle
    slot="question"
    name="auditieve_beperking"
    options={[
      "Harder praten",
      "Schrijven of typen",
      "Gebarentaal",
      "Ik weet het niet",
    ]}
  />

  <img class="mockup"
    src="/images/Mensenkennerskaderroller.png"
    alt="Mensenkenners logo"
  />
</MainLayout>