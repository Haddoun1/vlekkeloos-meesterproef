---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<MainLayout
  title="Stap 4"
  nextHref="/onboarding/step-5"
  backHref="/onboarding/step-3"
  headingText="Ervaring"
  bodyText="Hoe vaak heb je contact met mensen met een beperking?"
  step={4}
  totalSteps={9}
  stepId="onboarding_step-4"
  category="onboarding"
>
  <QuestionSingle
    slot="question"
    name="contact_frequentie"
    options={[
      "Bijna nooit",
      "Soms",
      "Regelmatig",
      "Dagelijks",
    ]}
  />

  <img class="mockup"
    src="/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<style>
  :global(.panel-left) {
    display: none !important;
  }

  :global(.panel-right) {
    margin: 2em 0 auto 0;
    height: 100%;
  }

  @media (min-width: 768px) {
    :global(.panel-left) {
      display: flex !important;
    }

    :global(.panel-right) {
        margin: 0 auto;
        height: 100%;
    }
  }

  .mockup{
    max-width: 400px !important;
  }
</style>
