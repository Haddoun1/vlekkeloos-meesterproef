---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<MainLayout
  title="Stap 7"
  nextHref="/onboarding/step-8"
  backHref="/onboarding/step-6"
  headingText="Kennis"
  bodyText="Een klant met een visuele beperking komt binnen. Wat doe je?"
  step={7}
  totalSteps={9}
  stepId="onboarding_step-7"
  category="onboarding"
  variant="steps-quiz"
>
  <QuestionSingle
    slot="question"
    name="visuele_beperking"
    options={[
      "Ik wacht af",
      "Ik vraag of ik kan helpen",
      "Ik weet het niet",
      "Ik help direct",
    ]}
  />

  <img class="mockup"
    src="../../public/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>