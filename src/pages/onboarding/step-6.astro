---
export const prerender = false;
import MainLayout from "../../layouts/Layout-onboarding.astro";
import QuestionSingle from "../../components/QuestionSingle.astro";
---

<MainLayout
  title="Stap 6"
  nextHref="/onboarding/step-7"
  backHref="/onboarding/step-5"
  headingText="Ervaring"
  bodyText="Weet je altijd hoe je iemand met een beperking kunt helpen?"
  step={6}
  totalSteps={9}
    stepId="onboarding_step-6"
  category="onboarding"
>
  <QuestionSingle
    slot="question"
    name="helpen_zekerheid"
    options={[
      "Vrijwel altijd",
      "Meestal wel",
      "Vaak niet",
      "Ik vermijd dit liever",
    ]}
  />

  <img class="mockup"
    src="/images/Mensenkennerskaderdoof.png"
    alt="Mensenkenners logo"
  />
</MainLayout>

<style>
  :global(.panel-left) {
    display: none !important;
  }

  :global(.panel-right) {
    margin: 2em 0 auto 0;
    height: 100%;
  }

  @media (min-width: 768px) {
    :global(.panel-left) {
      display: flex !important;
    }

    :global(.panel-right) {
        margin: 0 auto;
        height: 100%;
    }
  }

  .mockup{
    max-width: 400px !important;
  }
</style>
