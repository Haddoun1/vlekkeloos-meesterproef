---
// @ts-nocheck
export const prerender = false;
import MainLayout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';

import { supabase } from '../lib/supabase';

const courses = [
  {
    id: "deel_1",
    title: "Deel 1",
    image: "",
    progress: 0,
    href: "/deel-1/1",
    color: "#FF94E1",
  },
  {
    id: "deel_2",
    title: "Deel 2",
    image: "",
    progress: 0,
    href: "/deel-2/1",
    color: "#FF6631",
  },
  {
    id: "deel_3",
    title: "Deel 3",
    image: "",
    progress: 0,
    href: "/deel-3/1",
    color: "#E9F279",
  },
];

// Hier komen items zodra een gebruiker een cursus is begonnen.
const recentCourses = [
  {
    id: "onboarding",
    title: 'Onboarding',
    image: '',
    progress: 0,
    href: '/onboarding/step-1',
    color: '#2241DD',
  },
];
---

<MainLayout>
  <section class="dashboard">
    {recentCourses.length > 0 && (
      <>
        <h2 id="welcome">Ga verder waar je gebleven was</h2>

        <div class="carousel-wrapper">
          <ul class="carousel">
            {recentCourses.map((course) => (
              <li class="carousel-item" data-course-id={course.id}>
                <CourseCard
                  title={course.title}
                  image={course.image}
                  progress={course.progress}
                  href={course.href}
                  color={course.color}
                />
              </li>
            ))}
          </ul>
        </div>
      </>
    )}

    <h1>Mijn Cursussen</h1>

    <div class="carousel-wrapper">
      <ul class="carousel">
        {courses.map((course) => (
          <li class="carousel-item" data-course-id={course.id}>
            <CourseCard
              title={course.title}
              image={course.image}
              progress={course.progress}
              href={course.href}
              color={course.color}
            />
          </li>
        ))}
      </ul>
    </div>

  </section>
</MainLayout>

<script>
  // @ts-nocheck
  import { supabase } from "../lib/supabase";
  const { data: { user } } = await supabase.auth.getUser();

  async function loadProgress() {
    if (!user) return;

    const response = await fetch("/api/get-progress", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ userId: user.id })
    });

    const result = await response.json();
    const rows = result.data || [];

    const totals = {
      deel_1: 36,
      deel_2: 36,
      deel_3: 36,
      onboarding: 9
    };

    const completed = {
      deel_1: new Set(),
      deel_2: new Set(),
      deel_3: new Set(),
      onboarding: new Set()
    };

  rows.forEach((row) => {
    if (row.category === "deel-1") completed.deel_1.add(row.step_id);
    if (row.category === "deel-2") completed.deel_2.add(row.step_id);
    if (row.category === "deel-3") completed.deel_3.add(row.step_id);
    if (row.category === "onboarding") completed.onboarding.add(row.step_id);
  });

    Object.keys(completed).forEach((key) => {
      const percentage = Math.round(
        (completed[key].size / totals[key]) * 100
      );

      const card = document.querySelector(`[data-course-id="${key}"]`);
      if (!card) return;

      const progressText = card.querySelector("[data-progress-text]");
      const progressBar = card.querySelector("[data-progress-bar]");

      if (progressText) {
        progressText.textContent = `${percentage}%`;
      }

      if (progressBar) {
        progressBar.value = percentage;
      }
          });
        }

  loadProgress();

  const hour = new Date().getHours();

  let greeting = "";

  if (hour < 12) {
    greeting = "Goedemorgen";
  } else if (hour < 18) {
    greeting = "Goedemiddag";
  } else {
    greeting = "Goedenavond";
  }

if (user) {
  document.getElementById("welcome").innerText =
    `${greeting}, ${user.user_metadata.name}! Ga verder waar je gebleven was.`;
}

// Voor het maken van de backend
// https://chatgpt.com/c/6a1ea657-76d0-8397-851d-b3370b211cac
</script>

<style>
  .dashboard {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1, h2 {
    margin: 0 0 1.5rem;
    font-size: 2rem;
    color: #333;
  }

  h2 {
    margin-top: 2rem;
  }

  /* Carousel */
  .carousel-wrapper {
    position: relative;
  }

  .carousel {
    list-style: none;
    padding: 2rem 0;
    margin: 0;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel-item {
    flex: 0 0 200px;
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .carousel-item {
      flex: 0 0 350px;
    }

    h1, h2 {
      margin-bottom: 0rem;
    }
  }
</style>