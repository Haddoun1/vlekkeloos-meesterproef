---
// @ts-nocheck
export const prerender = false;
import MainLayout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';

const courses = [
  {
    title: 'Cursus 1',
    image: '',
    progress: 20,
    href: '',
    color: '#2241DD',
  },
  {
    title: 'Cursus 2',
    image: '',
    progress: 40,
    href: '',
    color: '#FF94E1',
  },
  {
    title: 'Cursus 3',
    image: '',
    progress: 60,
    href: '',
    color: '#FF6631',
  },
  {
    title: 'Cursus 4',
    image: '',
    progress: 80,
    href: '',
    color: '#E9F279',
  },
  {
    title: 'Cursus 5',
    image: '',
    progress: 100,
    href: '',
    color: '#B1F2D9',
  },
];
---

<MainLayout>
  <section class="dashboard">
    <h1>Mijn Cursussen</h1>

    <ul>
      {courses.map((course) => (
        <li>
          <CourseCard
            title={course.title}
            image={course.image}
            progress={course.progress}
            href={course.href}
            color={course.color}
          />
        </li>
      ))}
    </ul>
  </section>
</MainLayout>

<style>
  .dashboard {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    margin: 0 0 1.5rem;
    font-size: 2rem;
    color: #333;
  }

ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
</style>