---
// @ts-nocheck

// Deze pagina mag niet vooraf statisch gebouwd worden,
// omdat hij eerst moet checken of iemand is ingelogd en admin is.
export const prerender = false;

// Importeert de server-side Supabase client.
// Deze kan cookies lezen en dus veilig controleren wie is ingelogd.
import { createSupabaseServerClient } from "../../lib/supabaseServer";

// Maakt een Supabase client aan voor deze pagina.
const supabase = createSupabaseServerClient(Astro);

// Haalt de huidige ingelogde gebruiker op.
const {
  data: { user },
} = await supabase.auth.getUser();

// Als er geen gebruiker is ingelogd, stuur diegene naar de admin login.
if (!user) {
  return Astro.redirect("/admin/login");
}

// Haalt het profiel van de gebruiker op om te controleren of die admin is.
const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("role")
  .eq("id", user.id)
  .single();

// Als er een fout is of de gebruiker is geen admin,
// stuur diegene terug naar het normale dashboard.
if (profileError || profile?.role !== "admin") {
  return Astro.redirect("/");
}

// Haalt alle opgeslagen cursusvoortgang op uit Supabase.
// Nieuwste records komen bovenaan.
const { data: progress, error } = await supabase
  .from("course_progress")
  .select("*")
  .order("created_at", { ascending: false });

// Als er geen data is, gebruiken we een lege array zodat de pagina niet crasht.
const records = progress || [];

// Telt hoeveel voortgangsrecords er totaal zijn opgeslagen.
const totalRecords = records.length;

// Telt alle seconden bij elkaar op die gebruikers actief zijn geweest.
const totalSeconds = records.reduce(
  (sum, row) => sum + (row.duration_seconds || 0),
  0,
);

// Zet seconden om naar minuten.
const totalMinutes = Math.round(totalSeconds / 60);

// Telt hoeveel unieke gebruikers er zijn.
const uniqueUsers = new Set(records.map((row) => row.user_id)).size;

// Groepeert alle records eerst per cursus/categorie,
// en daarna per gebruiker.
const byCategory: any = records.reduce((acc: any, row: any) => {
  const cat = row.category || "Onbekend";
  const uid = row.user_id || "anonymous";

  // Maakt een categorie aan als die nog niet bestaat.
  if (!acc[cat]) acc[cat] = {};

  // Maakt een gebruiker aan binnen de categorie als die nog niet bestaat.
  if (!acc[cat][uid]) {
    acc[cat][uid] = {
      name: row.name || row.user_id || "Onbekend",
      userId: uid,
      stepCount: 0,
      totalSeconds: 0,
      lastSeen: row.created_at,
      lastStep: row.step_id,
    };
  }

  // Verhoogt het aantal opgeslagen stappen voor deze gebruiker.
  acc[cat][uid].stepCount += 1;

  // Telt de actieve tijd van deze gebruiker op.
  acc[cat][uid].totalSeconds += row.duration_seconds || 0;

  // Checkt of dit record nieuwer is dan de laatst bekende activiteit.
  if (new Date(row.created_at) > new Date(acc[cat][uid].lastSeen)) {
    acc[cat][uid].lastSeen = row.created_at;
    acc[cat][uid].lastStep = row.step_id;
  }

  return acc;
}, {});

// Zet het gegroepeerde object om naar een array,
// zodat Astro er makkelijk doorheen kan loopen.
const categories = Object.entries(byCategory).map(([name, usersObj]) => ({
  name,
  users: Object.values(usersObj as any),
}));
---

<!-- Laadt Google Fonts voor het admin dashboard -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap"
  rel="stylesheet"
/>

<main>
  <div class="shell">
    <!-- Bovenste balk van het dashboard -->
    <header>
      <div class="header-left">
        <span class="logo-dot"></span>
        <h1>Mensenkenners</h1>
      </div>

      <!-- Label zodat duidelijk is dat dit het admin dashboard is -->
      <span class="badge">Admin</span>
    </header>

    <!-- Toont een foutmelding als Supabase data ophalen mislukt -->
    {
      error && (
        <div class="error-bar">
          <span>⚠</span> Fout bij ophalen data: {error.message}
        </div>
      )
    }

    <!-- Statistieken bovenaan het dashboard -->
    <section class="stats-grid">
      <article class="stat-card accent">
        <p class="stat-label">Opgeslagen stappen</p>
        <p class="stat-value">{totalRecords}</p>
      </article>

      <article class="stat-card">
        <p class="stat-label">Unieke gebruikers</p>
        <p class="stat-value">{uniqueUsers}</p>
      </article>

      <article class="stat-card">
        <p class="stat-label">Totale actieve tijd</p>
        <p class="stat-value">
          {totalMinutes}<span class="stat-unit">min</span>
        </p>
      </article>

      <article class="stat-card">
        <p class="stat-label">Cursussen actief</p>
        <p class="stat-value">{categories.length}</p>
      </article>
    </section>

    <!-- Lijst met cursussen/categorieën en gebruikersvoortgang -->
    <div class="cards">
      {
        categories.map((cat) => (
          <div class="card">
            {/* Header van één cursuskaart */}
            <div class="card-header">
              <div class="cat-info">
                <span class="cat-dot" />
                <h2>{cat.name}</h2>
              </div>

              {/* Kleine labels rechtsboven in de kaart */}
              <div class="pills">
                <span class="pill">
                  {cat.users.length} deelnemer
                  {cat.users.length !== 1 ? "s" : ""}
                </span>

                <span class="pill accent-pill">
                  {cat.users.reduce((s, u) => s + u.stepCount, 0)} stappen
                </span>
              </div>
            </div>

            {/* Tabel met gebruikersdata */}
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Stappen</th>
                    <th>Tijd besteed</th>
                    <th>Laatste stap</th>
                    <th>Laatst actief</th>
                  </tr>
                </thead>

                <tbody>
                  {cat.users.map((user) => (
                    <tr>
                      <td class="mono muted">{user.userId}</td>

                      <td>
                        <span class="step-count">{user.stepCount}</span>
                      </td>

                      <td class="mono">
                        {Math.round(user.totalSeconds / 60)} min
                      </td>

                      <td>
                        <span class="step-tag">{user.lastStep}</span>
                      </td>

                      <td class="mono muted">
                        {new Date(user.lastSeen).toLocaleString("nl-NL")}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Admin tools onderaan het dashboard -->
    <section class="admin-tools card">
      <div class="card-header">
        <div class="cat-info">
          <span class="cat-dot"></span>
          <h2>Admin Tools</h2>
        </div>
      </div>

      <div class="admin-tools-body">
        <!-- Formulier om een wachtwoord-resetmail te sturen -->
        <p class="tool-description">
          Verstuur een wachtwoord-resetlink naar een gebruiker.
        </p>

        <form id="reset-form">
          <input
            id="reset-email"
            type="email"
            placeholder="E-mailadres gebruiker"
            required
          />

          <button class="resetBtn" type="submit">Stuur resetlink</button>

          <!-- Hier komt feedback te staan na versturen -->
          <p id="reset-message"></p>
        </form>

        <!-- Formulier om adminrechten te beheren -->
        <p class="tool-description">
          Maak een gebruiker admin, of verwijder admin rechten.
        </p>

        <form id="admin-role-form">
          <input
            id="admin-email"
            type="email"
            placeholder="E-mailadres gebruiker"
            required
          />

          <button type="button" id="make-admin-btn" class="resetBtn">
            Maak admin
          </button>

          <button type="button" id="remove-admin-btn" class="resetBtn">
            Verwijder admin
          </button>

          <!-- Hier komt feedback te staan na admin-actie -->
          <p id="admin-role-message"></p>
        </form>
      </div>
    </section>
  </div>
</main>

<script>
  // Zorgt ervoor dat TypeScript geen errors geeft in dit browser-script.
  // @ts-nocheck

  // Importeert de normale Supabase client voor browser-acties.
  import { supabase } from "../../lib/supabase";

  // Elementen voor het reset-password formulier.
  const form = document.getElementById("reset-form");
  const message = document.getElementById("reset-message");

  // Luistert naar het versturen van het resetformulier.
  form.addEventListener("submit", async (e) => {
    // Voorkomt dat de pagina herlaadt.
    e.preventDefault();

    // Haalt het ingevulde e-mailadres op.
    const email = document.getElementById("reset-email").value;

    // Stuurt via Supabase een resetmail naar de gebruiker.
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/update-password`,
    });

    // Toont eerst een simpele melding.
    message.textContent = error
      ? "Resetmail versturen mislukt."
      : "Resetmail verstuurd.";

    // Als er een fout is, toon de echte foutmelding in de console en op de pagina.
    if (error) {
      console.error(error);
      message.textContent = error.message;
      return;
    }
  });

  // Elementen voor het beheren van adminrechten.
  const adminEmailInput = document.getElementById("admin-email");
  const makeAdminBtn = document.getElementById("make-admin-btn");
  const removeAdminBtn = document.getElementById("remove-admin-btn");
  const adminRoleMessage = document.getElementById("admin-role-message");

  // Functie die een gebruiker admin maakt of adminrechten verwijdert.
  async function updateAdminRole(action) {
    // Haalt het ingevulde e-mailadres op.
    const email = adminEmailInput.value;

    // Stuurt de actie naar een server-side API-route.
    // De server controleert daarna of de huidige gebruiker admin is.
    const response = await fetch("/api/admin-role", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ email, action }),
    });

    // Leest het antwoord van de API-route.
    const result = await response.json();

    // Toont de melding op de pagina.
    adminRoleMessage.textContent = result.message;
  }

  // Klik op "Maak admin".
  makeAdminBtn.addEventListener("click", () => {
    updateAdminRole("add");
  });

  // Klik op "Verwijder admin".
  removeAdminBtn.addEventListener("click", () => {
    updateAdminRole("remove");
  });
</script>

<style>
  /*
    Reset:
    zorgt ervoor dat padding/margin overal hetzelfde begint.
  */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /*
    Algemene kleuren en fonts voor het admin dashboard.
    Deze variabelen worden later overal hergebruikt.
  */
  :root {
    --accent: #2ab789;
    --accent-light: #2ab78912;
    --accent-mid: #2ab78930;
    --bg: #f7f8f7;
    --surface: #ffffff;
    --border: #e8eae8;
    --text: #111c17;
    --muted: #7a8c84;
    --font: "DM Sans", sans-serif;
    --mono: "DM Mono", monospace;
  }

  /*
    Formulier voor wachtwoord reset.
  */
  #reset-form {
    display: flex;
    padding: 1rem;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /*
    Formulier voor adminrechten beheren.
  */
  #admin-role-form {
    display: flex;
    padding: 1rem;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /*
    Inputveld voor resetmail.
  */
  #reset-email {
    flex: 1;
    min-width: 260px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--surface);
    color: var(--text);
    font-family: var(--font);
    font-size: 0.875rem;
  }

  /*
    Inputveld voor admin e-mailadres.
  */
  #admin-email {
    flex: 1;
    min-width: 260px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--surface);
    color: var(--text);
    font-family: var(--font);
    font-size: 0.875rem;
  }

  /*
    Basisstijl van de pagina.
  */
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /*
    Bovenste header met titel links en admin badge rechts.
  */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  /*
    Korte uitlegtekst bij admin tools.
  */
  .tool-description {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0.5rem 0 0 1.5rem;
  }

  /*
    Knoppen in admin tools.
  */
  .resetBtn {
    font-family: var(--font-semi-bold);
    font-size: var(--size-sm);
    letter-spacing: 0.06em;
    background: var(--color-cyan);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 99px;
    padding: 0.25rem 0.85rem;
    color: var(--color-text);
    margin: 0;
    text-decoration: none;
    max-width: fit-content;
    cursor: pointer;
  }

  /*
    Hover-effect voor admin tool knoppen.
  */
  .resetBtn:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(42, 183, 137, 0.25);
    transition: transform 0.2s;
  }

  /*
    Centrale container van het dashboard.
  */
  .shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }

  /*
    Linkerkant van de header: bolletje + titel.
  */
  .header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /*
    Groen bolletje naast Mensenkenners.
  */
  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-mid);
  }

  /*
    Titel bovenaan.
  */
  h1 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  /*
    Admin label rechtsboven.
  */
  .badge {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-light);
    border: 1px solid var(--accent-mid);
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
  }

  /*
    Foutmelding als database ophalen mislukt.
  */
  .error-bar {
    background: #fff5f5;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  /*
    Grid met statistiekkaarten bovenaan.
  */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  /*
    Eén statistiekkaart.
  */
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    transition: box-shadow 0.2s;
  }

  /*
    Subtiele hover op statistiekkaart.
  */
  .stat-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  /*
    Accentkaart, bijvoorbeeld de eerste statistiek.
  */
  .stat-card.accent {
    background: var(--accent-light);
    border-color: var(--accent-mid);
  }

  .stat-card.accent .stat-value {
    color: var(--accent);
  }

  /*
    Kleine tekst boven een statistiek.
  */
  .stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  /*
    Grote waarde van een statistiek.
  */
  .stat-value {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  /*
    Eenheid achter statistiek, zoals "min".
  */
  .stat-unit {
    font-size: 1rem;
    font-weight: 400;
    color: var(--muted);
    margin-left: 0.2rem;
  }

  /*
    Container voor alle cursuskaarten.
  */
  .cards {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /*
    Algemene kaartstijl.
  */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  /*
    Header binnen een kaart.
  */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /*
    Categorie-info links in kaartheader.
  */
  .cat-info {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  /*
    Klein groen puntje bij categorie.
  */
  .cat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /*
    Cursustitel in kaartheader.
  */
  h2 {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  /*
    Kleine labels rechts in kaartheader.
  */
  .pills {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .pill {
    font-family: var(--mono);
    font-size: 0.72rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
  }

  /*
    Accentlabel voor aantal stappen.
  */
  .accent-pill {
    color: var(--accent);
    background: var(--accent-light);
    border-color: var(--accent-mid);
  }

  /*
    Zorgt dat tabellen op kleine schermen horizontaal kunnen scrollen.
  */
  .table-wrap {
    overflow-x: auto;
  }

  /*
    Tabel met gebruikersvoortgang.
  */
  table {
    width: 100%;
    border-collapse: collapse;
  }

  /*
    Tabelkoppen.
  */
  th {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    padding: 0.65rem 1.5rem;
    text-align: left;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  /*
    Tabelcellen.
  */
  td {
    padding: 0.85rem 1.5rem;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--border);
  }

  /*
    Geen border onder de laatste rij.
  */
  tr:last-child td {
    border-bottom: none;
  }

  /*
    Hover-effect voor tabelrijen.
  */
  tr:hover td {
    background: var(--accent-light);
  }

  /*
    Eventuele naamcel met avatar.
  */
  .name-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 500;
  }

  /*
    Avatarstijl, momenteel voorbereid voor gebruik.
  */
  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent-mid);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /*
    Badge met aantal stappen.
  */
  .step-count {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.15rem 0.55rem;
    border-radius: 6px;
  }

  /*
    Badge met laatst bezochte stap.
  */
  .step-tag {
    font-family: var(--mono);
    font-size: 0.72rem;
    background: var(--accent-light);
    border: 1px solid var(--accent-mid);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  /*
    Monospace tekst voor IDs en technische data.
  */
  .mono {
    font-family: var(--mono);
    font-size: 0.8rem;
  }

  /*
    Gedempte tekstkleur.
  */
  .muted {
    color: var(--muted);
  }

  /*
    Op mobiel worden statistieken 2 per rij gezet.
  */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

