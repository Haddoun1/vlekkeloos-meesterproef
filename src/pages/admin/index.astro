---
// @ts-nocheck
import { supabase } from "../../lib/supabase";

const { data: progress, error } = await supabase
  .from("course_progress")
  .select("*")
  .order("created_at", { ascending: false });

const records = progress || [];

const totalRecords = records.length;
const totalSeconds = records.reduce((sum, row) => sum + (row.duration_seconds || 0), 0);
const totalMinutes = Math.round(totalSeconds / 60);
const uniqueUsers = new Set(records.map((row) => row.user_id)).size;

// Group by category → then by user
const byCategory = records.reduce((acc, row) => {
  const cat = row.category || "Onbekend";
  const uid = row.user_id || "anonymous";

  if (!acc[cat]) acc[cat] = {};

  if (!acc[cat][uid]) {
    acc[cat][uid] = {
      name: row.name || row.user_id || "Onbekend",
      userId: uid,
      stepCount: 0,
      totalSeconds: 0,
      lastSeen: row.created_at,
      lastStep: row.step_id,
    };
  }

  acc[cat][uid].stepCount += 1;
  acc[cat][uid].totalSeconds += row.duration_seconds || 0;

  if (new Date(row.created_at) > new Date(acc[cat][uid].lastSeen)) {
    acc[cat][uid].lastSeen = row.created_at;
    acc[cat][uid].lastStep = row.step_id;
  }

  return acc;
}, {});

const categories = Object.entries(byCategory).map(([name, usersObj]) => ({
  name,
  users: Object.values(usersObj),
}));
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

<div class="shell">
  <header>
    <div class="header-left">
      <span class="logo-dot"></span>
      <h1>Mensenkenners</h1>
    </div>
    <span class="badge">Admin</span>
  </header>

  {error && (
    <div class="error-bar">
      <span>⚠</span> Fout bij ophalen data: {error.message}
    </div>
  )}

  <section class="stats-grid">
    <article class="stat-card accent">
      <p class="stat-label">Opgeslagen stappen</p>
      <p class="stat-value">{totalRecords}</p>
    </article>
    <article class="stat-card">
      <p class="stat-label">Unieke gebruikers</p>
      <p class="stat-value">{uniqueUsers}</p>
    </article>
    <article class="stat-card">
      <p class="stat-label">Totale actieve tijd</p>
      <p class="stat-value">{totalMinutes}<span class="stat-unit">min</span></p>
    </article>
    <article class="stat-card">
      <p class="stat-label">Cursussen actief</p>
      <p class="stat-value">{categories.length}</p>
    </article>
  </section>

  <div class="cards">
    {categories.map((cat) => (
      <div class="card">
        <div class="card-header">
          <div class="cat-info">
            <span class="cat-dot"></span>
            <h2>{cat.name}</h2>
          </div>
          <div class="pills">
            <span class="pill">{cat.users.length} deelnemer{cat.users.length !== 1 ? "s" : ""}</span>
            <span class="pill accent-pill">
              {cat.users.reduce((s, u) => s + u.stepCount, 0)} stappen
            </span>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Stappen</th>
                <th>Tijd besteed</th>
                <th>Laatste stap</th>
                <th>Laatst actief</th>
              </tr>
            </thead>
            <tbody>
              {cat.users.map((user) => (
                <tr>
                  <td class="mono muted">{user.userId}</td>
                  <td>
                    <span class="step-count">{user.stepCount}</span>
                  </td>
                  <td class="mono">{Math.round(user.totalSeconds / 60)} min</td>
                  <td><span class="step-tag">{user.lastStep}</span></td>
                  <td class="mono muted">
                    {new Date(user.lastSeen).toLocaleString("nl-NL")}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --accent: #2AB789;
    --accent-light: #2AB78912;
    --accent-mid: #2AB78930;
    --bg: #f7f8f7;
    --surface: #ffffff;
    --border: #e8eae8;
    --text: #111c17;
    --muted: #7a8c84;
    --font: 'DM Sans', sans-serif;
    --mono: 'DM Mono', monospace;
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  .shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-mid);
  }

  h1 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .badge {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-light);
    border: 1px solid var(--accent-mid);
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
  }

  .error-bar {
    background: #fff5f5;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    transition: box-shadow 0.2s;
  }

  .stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }

  .stat-card.accent {
    background: var(--accent-light);
    border-color: var(--accent-mid);
  }

  .stat-card.accent .stat-value { color: var(--accent); }

  .stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-unit {
    font-size: 1rem;
    font-weight: 400;
    color: var(--muted);
    margin-left: 0.2rem;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cat-info {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .cat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  h2 {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .pills {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .pill {
    font-family: var(--mono);
    font-size: 0.72rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
  }

  .accent-pill {
    color: var(--accent);
    background: var(--accent-light);
    border-color: var(--accent-mid);
  }

  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    padding: 0.65rem 1.5rem;
    text-align: left;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  td {
    padding: 0.85rem 1.5rem;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--border);
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--accent-light); }

  .name-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 500;
  }

  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent-mid);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-count {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.15rem 0.55rem;
    border-radius: 6px;
  }

  .step-tag {
    font-family: var(--mono);
    font-size: 0.72rem;
    background: var(--accent-light);
    border: 1px solid var(--accent-mid);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .mono { font-family: var(--mono); font-size: 0.8rem; }
  .muted { color: var(--muted); }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>