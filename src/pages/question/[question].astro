---
// @ts-nocheck
import data from "../../data/mensenkennersvragen.json";

export async function getStaticPaths() {
  const questions = data.flow.filter((item) => item.type === "Question");

  return questions.map((question, index) => ({
    params: {
      question: String(index + 1),
    },
    props: {
      question,
      index,
      total: questions.length,
    },
  }));
}

const { question, index, total } = Astro.props;

const currentPage = index + 1;
const previousPage = currentPage > 1 ? `/question/${currentPage - 1}` : null;
const nextPage = currentPage < total ? `/question/${currentPage + 1}` : null;
---

<h1>Vraag {currentPage} van {total}</h1>

<section>
  {question.title && <h2>{question.title}</h2>}

  {question.question && <h3>{question.question}</h3>}

  {question.description && <p>{question.description}</p>}

  {question.text && <p>{question.text}</p>}

  {question.options && (
    <ul>
      {question.options.map((option) => (
        <li>
          <button>{option.text}</button>
        </li>
      ))}
    </ul>
  )}
</section>

<nav>
  {previousPage && <a href={previousPage}>Vorige</a>}
  {nextPage && <a href={nextPage}>Volgende</a>}
</nav>